@model GymManagement.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
    var initials = "";
    var nameParts = Model.FullName?.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    if (nameParts != null && nameParts.Length > 0)
    {
        initials = nameParts[0][0].ToString().ToUpper();
        if (nameParts.Length > 1) initials += nameParts[^1][0].ToString().ToUpper();
    }
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .profile-card, .info-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }
    .profile-cover {
        height: 120px;
        background: linear-gradient(135deg, #1e3a8a, #3b82f6, #7c3aed);
        border-radius: 18px 18px 0 0;
        position: relative;
    }
    .profile-avatar-wrap {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        border: 4px solid #fff;
        position: absolute;
        left: 24px;
        bottom: -55px;
        overflow: hidden;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.2);
    }
    .profile-avatar-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }
    .profile-avatar-initials {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 2.2rem;
        font-weight: 700;
    }
    .profile-body { padding: 70px 24px 24px; }
    .profile-name { font-size: 1.6rem; font-weight: 700; margin-bottom: 6px; }
    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .info-tile {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 16px;
        height: 100%;
    }
    .info-tile label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 6px;
    }
    .info-tile .value { font-weight: 600; color: #0f172a; word-break: break-word; }
    .btn-camera {
        position: absolute;
        right: 24px;
        bottom: -20px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: none;
        background: #fff;
        color: #2563eb;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.15);
    }
    .btn-camera:hover { background: #eff6ff; color: #1d4ed8; }
    .form-control, .form-select, .btn { border-radius: 10px; }
    @@media (max-width: 768px) {
        .profile-avatar-wrap { left: 50%; transform: translateX(-50%); }
        .btn-camera { right: 50%; transform: translateX(50%); }
        .profile-body { padding-top: 80px; text-align: center; }
    }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1"><i class="fa-solid fa-user-circle me-2"></i>My Profile</h2>
            <p class="mb-0 opacity-75">Manage your account details and profile photo</p>
        </div>
        <a asp-action="ChangePassword" class="btn btn-light" data-full-nav="true">
            <i class="fa-solid fa-key me-2"></i>Change Password
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card profile-card">
            <div class="profile-cover">
                <div class="profile-avatar-wrap" id="profileAvatarWrapper">
                    <div class="profile-avatar-initials" id="profileAvatarInitials">@initials</div>
                    <img src="/uploads/Profiles/@(Model.ProfilePhoto ?? "")" alt="Profile" id="profileImage">
                </div>
                <button type="button" class="btn-camera" data-bs-toggle="modal" data-bs-target="#avatarModal" title="Change photo">
                    <i class="fa-solid fa-camera"></i>
                </button>
            </div>
            <div class="profile-body">
                <h3 class="profile-name">@Model.FullName</h3>
                <span class="role-badge"><i class="fa-solid fa-user-tag"></i> @Model.RoleName</span>
                <hr class="my-4" />
                <div class="d-grid gap-2">
                    <div class="info-tile text-start">
                        <label>User ID</label>
                        <div class="value">#@Model.UserId</div>
                    </div>
                    <div class="info-tile text-start">
                        <label>Last Login</label>
                        <div class="value">@(Model.LastLogin?.ToString("dd MMM yyyy, hh:mm tt") ?? "Never")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card info-card mb-4">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-1"><i class="fa-solid fa-id-card me-2 text-primary"></i>Account Information</h5>
                <p class="text-muted mb-0 small">Your login and contact details</p>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="info-tile">
                            <label><i class="fa-solid fa-user me-1"></i> Full Name</label>
                            <div class="value">@Model.FullName</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-tile">
                            <label><i class="fa-solid fa-at me-1"></i> Username</label>
                            <div class="value">@Model.UserName</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-tile">
                            <label><i class="fa-solid fa-envelope me-1"></i> Email</label>
                            <div class="value">@(string.IsNullOrWhiteSpace(Model.Email) ? "Not set" : Model.Email)</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-tile">
                            <label><i class="fa-solid fa-shield-halved me-1"></i> Role</label>
                            <div class="value">@Model.RoleName</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card info-card">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="fw-bold mb-1"><i class="fa-solid fa-pen-to-square me-2 text-primary"></i>Edit Profile</h5>
                <p class="text-muted mb-0 small">Update your display name and email address</p>
            </div>
            <div class="card-body px-4 pb-4">
                <form id="profileEditForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Full Name</label>
                            <input type="text" id="editFullName" class="form-control" value="@Model.FullName" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" id="editEmail" class="form-control" value="@Model.Email" />
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary" id="saveProfileBtn">
                            <i class="fa-solid fa-save me-2"></i>Save Changes
                        </button>
                    </div>
                </form>
                <div id="profileSaveMessage" class="mt-3"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="avatarModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Update Profile Photo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="previewImage" src="/uploads/Profiles/@(Model.ProfilePhoto ?? "")" alt="Preview"
                     class="rounded-circle mb-3" style="width:120px;height:120px;object-fit:cover;border:3px solid #e2e8f0;">
                <input type="file" id="modalAvatarInput" class="form-control" accept="image/*">
                <small class="text-muted d-block mt-2">JPG, PNG, WebP, AVIF. Max 5MB.</small>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2">
                <button type="button" class="btn btn-outline-danger" onclick="deleteAvatar()">
                    <i class="fa-solid fa-trash me-1"></i>Remove
                </button>
                <button type="button" class="btn btn-primary" onclick="saveAvatar()">
                    <i class="fa-solid fa-upload me-1"></i>Upload
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const fullName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FullName ?? ""));

        function getInitials(name) {
            if (!name) return 'U';
            const parts = name.trim().split(/\s+/);
            if (parts.length === 1) return parts[0].charAt(0).toUpperCase();
            return (parts[0].charAt(0) + parts[parts.length - 1].charAt(0)).toUpperCase();
        }

        function stringToColor(str) {
            let hash = 0;
            for (let i = 0; i < str.length; i++) hash = str.charCodeAt(i) + ((hash << 5) - hash);
            return `hsl(${hash % 360}, 65%, 45%)`;
        }

        function updateAvatarDisplay(photoPath, name) {
            const initialsEl = document.getElementById('profileAvatarInitials');
            const imgEl = document.getElementById('profileImage');
            const preview = document.getElementById('previewImage');

            if (photoPath) {
                const url = photoPath.startsWith('/') ? photoPath : '/' + photoPath;
                imgEl.src = url + '?t=' + Date.now();
                imgEl.style.display = 'block';
                initialsEl.style.display = 'none';
                if (preview) preview.src = url + '?t=' + Date.now();
            } else {
                initialsEl.textContent = getInitials(name);
                initialsEl.style.background = stringToColor(name || 'User');
                initialsEl.style.display = 'flex';
                imgEl.style.display = 'none';
                if (preview) preview.src = '';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            updateAvatarDisplay(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProfilePhoto ?? "")), fullName);

            document.getElementById('modalAvatarInput')?.addEventListener('change', function (e) {
                const file = e.target.files?.[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = ev => document.getElementById('previewImage').src = ev.target.result;
                reader.readAsDataURL(file);
            });

            document.getElementById('profileEditForm')?.addEventListener('submit', async function (e) {
                e.preventDefault();
                const btn = document.getElementById('saveProfileBtn');
                const msg = document.getElementById('profileSaveMessage');
                btn.disabled = true;

                const payload = {
                    fullName: document.getElementById('editFullName').value,
                    email: document.getElementById('editEmail').value,
                    userId: @Model.UserId
                };

                try {
                    const res = await fetch('/Profile/UpdateProfile', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    msg.innerHTML = data.success
                        ? `<div class="alert alert-success mb-0">${data.message}</div>`
                        : `<div class="alert alert-danger mb-0">${data.message}</div>`;
                    if (data.success) {
                        document.querySelector('.profile-name').textContent = payload.fullName;
                    }
                } catch {
                    msg.innerHTML = `<div class="alert alert-danger mb-0">Failed to update profile.</div>`;
                } finally {
                    btn.disabled = false;
                }
            });
        });

        async function uploadAvatar(file) {
            if (!file || file.size > 5 * 1024 * 1024) {
                alert('Please choose an image under 5MB.');
                return;
            }

            const formData = new FormData();
            formData.append('avatar', file);

            const res = await fetch('/Profile/UploadAvatar', { method: 'POST', body: formData });
            const data = await res.json();

            if (data.success) {
                updateAvatarDisplay(data.photoUrl, fullName);
                bootstrap.Modal.getInstance(document.getElementById('avatarModal'))?.hide();
            } else {
                alert(data.message || 'Upload failed.');
            }
        }

        function saveAvatar() {
            const file = document.getElementById('modalAvatarInput').files?.[0];
            if (file) uploadAvatar(file);
        }

        async function deleteAvatar() {
            if (!confirm('Remove profile photo?')) return;
            const res = await fetch('/Profile/DeleteAvatar', { method: 'POST' });
            const data = await res.json();
            if (data.success) {
                updateAvatarDisplay(null, fullName);
                bootstrap.Modal.getInstance(document.getElementById('avatarModal'))?.hide();
            } else {
                alert(data.message || 'Failed to remove photo.');
            }
        }
    </script>
}
