@model GymManagement.Models.ProductMaster

<form method="post" asp-action="Update">
    <input type="hidden" asp-for="ProductId" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Product Name</label>
            <input asp-for="ProductName" class="form-control" required />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Category</label>
            <select asp-for="Category" class="form-select">
                <option value="Supplement">Supplement</option>
                <option value="Apparel">Apparel</option>
                <option value="Accessory">Accessory</option>
                <option value="Other">Other</option>
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Vendor</label>
            <select asp-for="VendorId" class="form-select">
                <option value="">Select Vendor</option>
                @foreach (var v in ViewBag.Vendors)
                {
                    <option value="@v.VendorId">@v.VendorName</option>
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Unit Price (₹)</label>
            <input asp-for="UnitPrice" type="number" step="0.01" min="0" class="form-control" required />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Current Stock</label>
            <input asp-for="CurrentStock" type="number" min="0" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Reorder Level</label>
            <input asp-for="ReorderLevel" type="number" min="0" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Status</label>
            <select asp-for="IsActive" class="form-select">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
            </select>
        </div>
    </div>
    <div class="text-end">
        <button type="submit" class="btn btn-success">
            <i class="fas fa-save me-2"></i>Update Product
        </button>
    </div>
</form>
