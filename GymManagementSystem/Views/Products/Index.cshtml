@model List<GymManagement.Models.ProductMaster>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Product Master";

    int totalProducts = Model.Count;
    int lowStock = Model.Count(x => x.CurrentStock <= x.ReorderLevel);
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }
    .stats-card:hover {
        transform: translateY(-5px);
    }
    .form-control, .form-select { border-radius: 10px; }
    .btn { border-radius: 10px; }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">Product Master</h2>
            <p class="mb-0">Manage products, supplements, and merchandise</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "Products", allowImport = true })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "Products"))
            {
                <button class="btn btn-light btn-lg"
                        data-bs-toggle="collapse"
                        data-bs-target="#productForm">

                    <i class="fas fa-plus me-2"></i>
                    Add Product

                </button>
            }
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body">
                <h6>Total Products</h6>
                <h2>@totalProducts</h2>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card stats-card bg-warning text-dark">
            <div class="card-body">
                <h6>Low Stock Alerts</h6>
                <h2>@lowStock</h2>
            </div>
        </div>
    </div>
</div>

<div class="collapse mb-4" id="productForm">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Product</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Save">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label>Product Name</label>
                        <input type="text" name="ProductName" class="form-control" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Category</label>
                        <select name="Category" class="form-select">
                            <option value="">Select Category</option>
                            <option>Supplement</option>
                            <option>Apparel</option>
                            <option>Accessory</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Vendor</label>
                        <select name="VendorId" class="form-select">
                            <option value="">Select Vendor</option>
                            @foreach (var v in ViewBag.Vendors)
                            {
                                <option value="@v.VendorId">@v.VendorName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Unit Price (₹)</label>
                        <input type="number" step="0.01" min="0" name="UnitPrice" class="form-control" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Current Stock</label>
                        <input type="number" min="0" name="CurrentStock" class="form-control" value="0" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Reorder Level</label>
                        <input type="number" min="0" name="ReorderLevel" class="form-control" value="0" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-2"></i>Save Product
                </button>
            </form>
        </div>
    </div>
</div>

<!-- SEARCH -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row">
                <div class="col-md-5">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search Product Name..." />
                </div>
                <div class="col-md-3">
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        <option value="Supplement" selected="@(ViewBag.Category == "Supplement")">Supplement</option>
                        <option value="Apparel" selected="@(ViewBag.Category == "Apparel")">Apparel</option>
                        <option value="Accessory" selected="@(ViewBag.Category == "Accessory")">Accessory</option>
                        <option value="Other" selected="@(ViewBag.Category == "Other")">Other</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary">Search</button>
                    <a asp-action="Index" class="btn btn-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card shadow border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Product List (@Model.Count)</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Vendor</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Reorder At</th>
                        <th>Status</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Category</td>
                                <td>@item.VendorName</td>
                                <td>@item.UnitPrice</td>
                                <td>
                                    @if (item.CurrentStock <= item.ReorderLevel)
                                    {
                                        <span class="text-danger fw-bold">@item.CurrentStock (Low)</span>
                                    }
                                    else
                                    {
                                        @item.CurrentStock
                                    }
                                </td>
                                <td>@item.ReorderLevel</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                Context,
                                                                PermissionRepo,
                                                                "Products"))
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                onclick="loadProduct(@item.ProductId)">

                                            Edit

                                        </button>
                                    }
                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                Context,
                                                                PermissionRepo,
                                                                "Products"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.ProductId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete Product?')">

                                            Delete

                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">No Products Found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editProductModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Edit Product</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editProductContainer">
            </div>
        </div>
    </div>
</div>

<script>
    function loadProduct(id) {
        fetch('/Products/Edit/' + id)
        .then(response => response.text())
        .then(html => {
            document.getElementById('editProductContainer').innerHTML = html;
            new bootstrap.Modal(document.getElementById('editProductModal')).show();
        });
    }
</script>
