@model GymManagement.Models.Expense

<form method="post" asp-action="Update">
    <input type="hidden" name="ExpenseId" value="@Model.ExpenseId" />
    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Expense Head</label>
            <select name="ExpenseHeadId" class="form-select" required>
                <option value="">Select Category</option>
                @foreach (var head in ViewBag.ExpenseHeads)
                {
                    if (head.ExpenseHeadId == Model.ExpenseHeadId)
                    {
                        <option value="@head.ExpenseHeadId" selected>@head.HeadName</option>
                    }
                    else
                    {
                        <option value="@head.ExpenseHeadId">@head.HeadName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Amount (₹)</label>
            <input type="number" step="0.01" min="0" name="Amount" class="form-control" value="@Model.Amount.ToString("0.00")" required />
        </div>
        <div class="col-md-6 mb-3">
            <label>Expense Date</label>
            <input type="date" name="ExpenseDate" class="form-control" value="@Model.ExpenseDate.ToString("yyyy-MM-dd")" required />
        </div>
        <div class="col-md-6 mb-3">
            <label>Payment Mode</label>
            <select name="PaymentMode" class="form-select" required>
                @{
                    var modes = new[] { "Cash", "Card", "UPI", "Bank" };
                    foreach (var mode in modes)
                    {
                        if (Model.PaymentMode == mode)
                        {
                            <option value="@mode" selected>@mode</option>
                        }
                        else
                        {
                            <option value="@mode">@mode</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Paid To</label>
            <input type="text" name="PaidTo" class="form-control" value="@Model.PaidTo" />
        </div>
        <div class="col-md-6 mb-3">
            <label>Description</label>
            <input type="text" name="Description" class="form-control" value="@Model.Description" />
        </div>
        <div class="col-md-12 mb-3">
            <label>Remarks</label>
            <textarea name="Remarks" class="form-control" rows="2">@Model.Remarks</textarea>
        </div>
    </div>
    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-warning">
            <i class="fas fa-save me-2"></i>Update Expense
        </button>
    </div>
</form>
