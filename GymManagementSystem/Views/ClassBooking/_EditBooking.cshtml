@model GymManagement.Models.ClassBooking

<form method="post" asp-action="Update">
    <input type="hidden" name="BookingId" value="@Model.BookingId" />
    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Member</label>
            <select name="MemberId" class="form-select" required>
                <option value="">Select Member</option>
                @foreach (var member in ViewBag.Members)
                {
                    if (member.MemberId == Model.MemberId)
                    {
                        <option value="@member.MemberId" selected>@member.MemberCode - @member.MemberName</option>
                    }
                    else
                    {
                        <option value="@member.MemberId">@member.MemberCode - @member.MemberName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Class</label>
            <select name="ClassId" class="form-select" required id="editClassSelect">
                <option value="">Select Class</option>
                @foreach (var cls in ViewBag.Classes)
                {
                    if (cls.ClassId == Model.ClassId)
                    {
                        <option value="@cls.ClassId" selected data-amount="@cls.Amount">@cls.ClassName</option>
                    }
                    else
                    {
                        <option value="@cls.ClassId" data-amount="@cls.Amount">@cls.ClassName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Booking Date</label>
            <input type="date" name="BookingDate" class="form-control" value="@Model.BookingDate.ToString("yyyy-MM-dd")" required />
        </div>
        <div class="col-md-6 mb-3">
            <label>Amount (₹)</label>
            <input type="number" step="0.01" min="0" name="Amount" class="form-control" value="@Model.Amount?.ToString("0.00")" />
        </div>
        <div class="col-md-6 mb-3">
            <label>Status</label>
            <select name="Status" class="form-select" required>
                @if (Model.Status == "Confirmed")
                {
                    <option value="Confirmed" selected>Confirmed</option>
                    <option value="Cancelled">Cancelled</option>
                }
                else
                {
                    <option value="Confirmed">Confirmed</option>
                    <option value="Cancelled" selected>Cancelled</option>
                }
            </select>
        </div>
        <div class="col-md-12 mb-3">
            <label>Remarks</label>
            <textarea name="Remarks" class="form-control" rows="2">@Model.Remarks</textarea>
        </div>
    </div>
    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-warning">
            <i class="fas fa-save me-2"></i>Update Booking
        </button>
    </div>
</form>

<script>
    document.getElementById('editClassSelect').addEventListener('change', function() {
        var selectedOption = this.options[this.selectedIndex];
        var amount = selectedOption.getAttribute('data-amount');
        if (amount) {
            document.querySelector('input[name="Amount"]').value = amount;
        }
    });
</script>