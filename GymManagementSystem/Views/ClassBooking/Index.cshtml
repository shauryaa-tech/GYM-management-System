@model List<GymManagement.Models.ClassBooking>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Class Bookings";

    int totalBookings = Model.Count;
    int confirmedBookings = Model.Count(x => x.Status == "Confirmed");
    int cancelledBookings = Model.Count(x => x.Status == "Cancelled");
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }
    .stats-card:hover {
        transform: translateY(-5px);
    }
    .form-control, .form-select { border-radius: 10px; }
    .btn { border-radius: 10px; }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">Class Bookings</h2>
            <p class="mb-0">Manage class bookings and schedules</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "ClassBookings" })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "ClassBookings"))
            {
                <button class="btn btn-light btn-lg"
                        data-bs-toggle="collapse"
                        data-bs-target="#bookingForm">

                    <i class="fas fa-plus me-2"></i>
                    Add Booking

                </button>
            }
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body">
                <h6>Total Bookings</h6>
                <h2>@totalBookings</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card bg-success text-white">
            <div class="card-body">
                <h6>Confirmed</h6>
                <h2>@confirmedBookings</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card bg-danger text-white">
            <div class="card-body">
                <h6>Cancelled</h6>
                <h2>@cancelledBookings</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card bg-info text-white">
            <div class="card-body">
                <h6>Revenue</h6>
                <h2>@Model.Where(x => x.Status == "Confirmed").Sum(x => x.Amount ?? 0):C0</h2>
            </div>
        </div>
    </div>
</div>

<div class="collapse mb-4" id="bookingForm">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Booking</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Save">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label>Member</label>
                        <select name="MemberId" class="form-select" required>
                            <option value="">Select Member</option>
                            @foreach (var member in ViewBag.Members)
                            {
                                <option value="@member.MemberId">@member.MemberCode - @member.MemberName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Class</label>
                        <select name="ClassId" class="form-select" required id="classSelect">
                            <option value="">Select Class</option>
                            @foreach (var cls in ViewBag.Classes)
                            {
                                <option value="@cls.ClassId" data-amount="@cls.Amount" data-capacity="@cls.MaxCapacity">@cls.ClassName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Booking Date</label>
                        <input type="date" name="BookingDate" class="form-control" required />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Amount (₹)</label>
                        <input type="number" step="0.01" min="0" name="Amount" class="form-control" id="amountInput" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label>Remarks</label>
                        <input type="text" name="Remarks" class="form-control" placeholder="Optional remarks" />
                    </div>
                </div>
                <input type="hidden" name="Status" value="Confirmed" />
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-2"></i>Save Booking
                </button>
            </form>
        </div>
    </div>
</div>

<!-- SEARCH -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row">
                <div class="col-md-3">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search Member/Class..." />
                </div>
                <div class="col-md-2">
                    <select name="memberId" class="form-select">
                        <option value="">All Members</option>
                        @foreach (var member in ViewBag.Members)
                        {
                            if (ViewBag.MemberId != null && ViewBag.MemberId.ToString() == member.MemberId.ToString())
                            {
                                <option value="@member.MemberId" selected>@member.MemberName</option>
                            }
                            else
                            {
                                <option value="@member.MemberId">@member.MemberName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="classId" class="form-select">
                        <option value="">All Classes</option>
                        @foreach (var cls in ViewBag.Classes)
                        {
                            if (ViewBag.ClassId != null && ViewBag.ClassId.ToString() == cls.ClassId.ToString())
                            {
                                <option value="@cls.ClassId" selected>@cls.ClassName</option>
                            }
                            else
                            {
                                <option value="@cls.ClassId">@cls.ClassName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="status" class="form-select">
                        <option value="">All Status</option>
                        @if (ViewBag.Status == "Confirmed")
                        {
                            <option value="Confirmed" selected>Confirmed</option>
                            <option value="Cancelled">Cancelled</option>
                        }
                        else if (ViewBag.Status == "Cancelled")
                        {
                            <option value="Confirmed">Confirmed</option>
                            <option value="Cancelled" selected>Cancelled</option>
                        }
                        else
                        {
                            <option value="Confirmed">Confirmed</option>
                            <option value="Cancelled">Cancelled</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-primary">Search</button>
                    <a asp-action="Index" class="btn btn-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card shadow border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Booking List (@Model.Count)</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Member</th>
                        <th>Class</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Trainer</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th width="200">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.MemberCode</strong><br />
                                    <small>@item.MemberName</small>
                                </td>
                                <td>@item.ClassName</td>
                                <td>@item.BookingDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @(item.StartTime?.ToString(@"hh\:mm")) - @(item.EndTime?.ToString(@"hh\:mm"))
                                </td>
                                <td>@item.TrainerName</td>
                                <td>@item.Amount?.ToString("C0")</td>
                                <td>
                                    @if (item.Status == "Confirmed")
                                    {
                                        <span class="badge bg-success">Confirmed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                </td>
                                <td>
                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                        Context,
                                                                        PermissionRepo,
                                                                        "ClassBookings"))
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                onclick="loadBooking(@item.BookingId)">

                                            Edit

                                        </button>
                                    }
                                    @if (item.Status == "Confirmed" && GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                        Context,
                                                                        PermissionRepo,
                                                                        "ClassBookings"))
                                    {
                                        <a asp-action="CancelBooking"
                                           asp-route-id="@item.BookingId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Cancel this booking?')">

                                            Cancel

                                        </a>
                                    }
                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                        Context,
                                                                        PermissionRepo,
                                                                        "ClassBookings"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.BookingId"
                                           class="btn btn-outline-danger btn-sm"
                                           onclick="return confirm('Delete this booking permanently?')">

                                            Delete

                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">No Bookings Found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editBookingModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Edit Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editBookingContainer">
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('classSelect').addEventListener('change', function() {
        var selectedOption = this.options[this.selectedIndex];
        var amount = selectedOption.getAttribute('data-amount');
        if (amount) {
            document.getElementById('amountInput').value = amount;
        }
    });

    function loadBooking(id) {
        fetch('/ClassBooking/Edit/' + id)
        .then(response => response.text())
        .then(html => {
            document.getElementById('editBookingContainer').innerHTML = html;
            new bootstrap.Modal(document.getElementById('editBookingModal')).show();
        });
    }
</script>