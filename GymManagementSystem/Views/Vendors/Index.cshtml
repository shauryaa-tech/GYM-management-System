@model List<GymManagement.Models.VendorMaster>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Vendor Master";

    int totalVendors = Model.Count;
    int activeVendors = Model.Count(x => x.IsActive);
    int inactiveVendors = Model.Count(x => !x.IsActive);
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }
    .stats-card:hover {
        transform: translateY(-5px);
    }
    .form-control, .form-select { border-radius: 10px; }
    .btn { border-radius: 10px; }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">Vendor Master</h2>
            <p class="mb-0">Manage suppliers and vendors</p>
        </div>

        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "Vendors", allowImport = true })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "Vendors"))
            {
                <button class="btn btn-light btn-lg" 
                    data-bs-toggle="collapse"   
                    data-bs-target="#vendorForm">
                    <i class="fas fa-plus me-2"></i>
                    
                    Add Vendor
                </button>
            }
        </div>
        
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body">
                <h6>Total Vendors</h6>
                <h2>@totalVendors</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stats-card bg-success text-white">
            <div class="card-body">
                <h6>Active</h6>
                <h2>@activeVendors</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stats-card bg-dark text-white">
            <div class="card-body">
                <h6>Inactive</h6>
                <h2>@inactiveVendors</h2>
            </div>
        </div>
    </div>
</div>

<div class="collapse mb-4" id="vendorForm">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Vendor</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Save">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label>Vendor Name</label>
                        <input type="text" name="VendorName" class="form-control" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Contact Person</label>
                        <input type="text" name="ContactPerson" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Mobile Number</label>
                        <input type="text" name="MobileNo" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Email</label>
                        <input type="email" name="Email" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>GST No</label>
                        <input type="text" name="GSTNo" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Address</label>
                        <input type="text" name="Address" class="form-control" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-2"></i>Save Vendor
                </button>
            </form>
        </div>
    </div>
</div>

<!-- SEARCH -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row">
                <div class="col-md-8">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search Vendor Name, Contact Person, Mobile..." />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary">Search</button>
                    <a asp-action="Index" class="btn btn-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card shadow border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Vendor List (@Model.Count)</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Vendor Name</th>
                        <th>Contact Person</th>
                        <th>Mobile</th>
                        <th>Email</th>
                        <th>GST No</th>
                        <th>Status</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.VendorName</td>
                                <td>@item.ContactPerson</td>
                                <td>@item.MobileNo</td>
                                <td>@item.Email</td>
                                <td>@item.GSTNo</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                Context,
                                                                PermissionRepo,
                                                                "Vendors"))
                                    {
                                        <button class="btn btn-warning btn-sm" 
                                            onclick="loadVendor(@item.VendorId)">   
                                                Edit
                                        </button>
                                    }

                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                Context,
                                                                PermissionRepo,
                                                                "Vendors"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.VendorId" 
                                            class="btn btn-danger btn-sm" 
                                            onclick="return confirm('Delete Vendor?')">
                                            Delete
                                        </a>
                                    }
                                    
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">No Vendors Found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editVendorModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Edit Vendor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editVendorContainer">
            </div>
        </div>
    </div>
</div>

<script>
    function loadVendor(id) {
        fetch('/Vendors/Edit/' + id)
        .then(response => response.text())
        .then(html => {
            document.getElementById('editVendorContainer').innerHTML = html;
            new bootstrap.Modal(document.getElementById('editVendorModal')).show();
        });
    }
</script>
