@model List<GymManagement.Models.MemberMaster>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    int totalMembers = Model.Count;

    int activeMembers = Model.Count(x =>
        x.Status != "Inactive" &&
        x.PlanEndDate.Date >= DateTime.Today);

    int expiredMembers = Model.Count(x =>
        x.Status != "Inactive" &&
        x.PlanEndDate.Date < DateTime.Today);

    int inactiveMembers = Model.Count(x =>
        x.Status == "Inactive");
}

<style>

    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }

    .stats-card:hover {
        transform: translateY(-5px);
    }

    .member-photo {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        object-fit: cover;
    }

    .form-control,
    .form-select {
        border-radius: 10px;
    }

    .btn {
        border-radius: 10px;
    }

</style>

<div class="page-header">

    <div class="d-flex justify-content-between align-items-center">

        <div>

            <h2 class="fw-bold mb-1">
                Member Master
            </h2>

            <p class="mb-0">
                Manage gym members efficiently
            </p>

        </div>

        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "MemberMaster", allowImport = true })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "MemberMaster"))
            {
                <button class="btn btn-light btn-lg"
                        data-bs-toggle="collapse"
                        data-bs-target="#memberForm">
                    <i class="fas fa-plus me-2"></i>
                    Add Member
                </button>
            }
        </div>

    </div>

</div>

<div class="row mb-4">

    <div class="col-md-3">

        <div class="card stats-card bg-primary text-white">

            <div class="card-body">

                <h6>Total Members</h6>

                <h2>@totalMembers</h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card stats-card bg-success text-white">

            <div class="card-body">

                <h6>Active Members</h6>

                <h2>@activeMembers</h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card stats-card bg-danger text-white">

            <div class="card-body">

                <h6>Expired</h6>

                <h2>@expiredMembers</h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card stats-card bg-dark text-white">

            <div class="card-body">

                <h6>Inactive</h6>

                <h2>@inactiveMembers</h2>

            </div>

        </div>

    </div>

</div>

<div class="collapse mb-4" id="memberForm">

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Member</h5>
        </div>

        <div class="card-body">

            <form method="post" asp-action="Save">

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label>Member Name</label>
                        <input type="text"
                               name="MemberName"
                               class="form-control"
                               required />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Mobile Number</label>
                        <input type="text"
                               name="MobileNo"
                               class="form-control"
                               required />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Email</label>
                        <input type="email"
                               name="Email"
                               class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Gender</label>
                        <select name="Gender"
                                class="form-select">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Membership Plan</label>

                        <select id="PlanId"
                                name="PlanId"
                                class="form-select">

                            <option value="">Select Plan</option>

                            @foreach (var plan in ViewBag.Plans)
                            {
                                <option value="@plan.PlanId"
                                        data-duration="@plan.DurationMonths">
                                    @plan.PlanName
                                </option>
                            }

                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Interested In</label>
                        <select name="InterestedIn" class="form-select">
                            <option value="">Select Interest</option>
                            @foreach (var interest in GymManagement.Helpers.TrainerInterestOptions.All)
                            {
                                <option value="@interest">@interest</option>
                            }
                        </select>
                        <small class="text-muted">Trainer auto-assign (agar manually select na kiya ho)</small>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Trainer</label>

                        <select id="TrainerId"
                                name="TrainerId"
                                class="form-select">

                            <option value="">Auto Assign Trainer</option>

                            @foreach (var trainer in ViewBag.Trainers)
                            {
                                <option value="@trainer.StaffId">
                                    @trainer.StaffName
                                </option>
                            }

                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Join Date</label>

                        <input type="date"
                               id="JoinDate"
                               name="JoinDate"
                               class="form-control"
                               required />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Plan Start Date</label>

                        <input type="date"
                               id="PlanStartDate"
                               name="PlanStartDate"
                               class="form-control"
                               readonly />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Plan End Date</label>

                        <input type="date"
                               id="PlanEndDate"
                               name="PlanEndDate"
                               class="form-control"
                               readonly />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Height (CM)</label>

                        <input type="number"
                               min="0"
                               name="Height"
                               class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Weight (KG)</label>

                        <input type="number"
                               min="0"
                               name="Weight"
                               class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Blood Group</label>

                        <input type="text"
                               name="BloodGroup"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Emergency Contact</label>

                        <input type="text"
                               name="EmergencyContact"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Address</label>

                        <input type="text"
                               name="Address"
                               class="form-control" />
                    </div>

                </div>

                <button type="submit"
                        class="btn btn-success">

                    <i class="fas fa-save me-2"></i>
                    Save Member

                </button>

            </form>

        </div>

    </div>

</div>

<!-- SEARCH -->

<div class="card shadow-sm border-0 mb-4">

    <div class="card-body">

        <form method="get">

            <div class="row">

                <div class="col-md-5">

                    <input type="text"
                           name="search"
                           value="@ViewBag.Search"
                           class="form-control"
                           placeholder="Search Name, Mobile, Code..." />

                </div>

                <div class="col-md-3">

                    <select name="status"
                            class="form-select">

                        <option value="">
                            All Status
                        </option>

                        <option value="Active">
                            Active
                        </option>

                        <option value="Expired">
                            Expired
                        </option>

                        <option value="Inactive">
                            Inactive
                        </option>

                    </select>

                </div>

                <div class="col-md-4">

                    <button class="btn btn-primary">
                        Search
                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        Reset
                    </a>

                </div>

            </div>

        </form>

    </div>

</div>

<!-- MEMBER TABLE -->

<div class="card shadow border-0">

    <div class="card-header bg-dark text-white">

        <h5 class="mb-0">
            Members (@Model.Count)
        </h5>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-light">

                    <tr>

                        <th>Code</th>
                        <th>Name</th>
                        <th>Mobile</th>
                        <th>Plan</th>
                        <th>Trainer</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th width="180">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    @item.MemberCode
                                </td>

                                <td>
                                    @item.MemberName
                                </td>

                                <td>
                                    @item.MobileNo
                                </td>

                                <td>
                                    @item.PlanName
                                </td>

                                <td>
                                    @item.TrainerName
                                </td>

                                <td>
                                    @item.PlanEndDate.ToString("dd-MMM-yyyy")
                                </td>

                                <td>

                                    @if (item.Status == "Inactive")
{
                                    <span class="badge bg-secondary">
                                        Inactive
                                    </span>
                                }
                                else if (item.PlanEndDate.Date < DateTime.Today)
                                {
                                    <span class="badge bg-danger">
                                        Expired
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
}

                                </td>

                                <td>

                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                Context,
                                                                PermissionRepo,
                                                                "MemberMaster"))
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                onclick="loadMember(@item.MemberId)">
                                            Edit
                                        </button>
                                    }

                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                Context,
                                                                PermissionRepo,
                                                                "MemberMaster"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.MemberId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete Member?')">

                                            Delete

                                        </a>
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="9"
                                class="text-center text-muted">

                                No Members Found

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- EDIT MODAL -->

<div class="modal fade"
     id="editMemberModal">

    <div class="modal-dialog modal-xl">

        <div class="modal-content">

            <div class="modal-header bg-warning">

                <h5 class="modal-title">

                    Edit Member

                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body"
                 id="editMemberContainer">
            </div>

        </div>

    </div>

</div>

<script>

    function loadMember(id)
    {
        fetch('/MemberMasters/Edit/' + id)
        .then(response => response.text())
        .then(html =>
        {
            document.getElementById(
                'editMemberContainer'
            ).innerHTML = html;

            new bootstrap.Modal(
                document.getElementById(
                    'editMemberModal'
                )
            ).show();
        });
    }

    document.addEventListener(
    "DOMContentLoaded",
    function()
    {
        document.querySelectorAll(
            'input[type="number"]'
        ).forEach(input =>
        {
            input.addEventListener(
                'input',
                function()
                {
                    if(this.value < 0)
                    {
                        this.value = 0;
                    }
                });
        });

        const plan =
            document.getElementById("PlanId");

        const join =
            document.getElementById("JoinDate");

        function calculateDates()
        {
            if(!plan.value || !join.value)
            {
                return;
            }

            const months =
                parseInt(
                    plan.selectedOptions[0]
                    .dataset.duration
                );

            const start =
                new Date(join.value);

            const end =
                new Date(join.value);

            end.setMonth(
                end.getMonth() + months
            );

            document.getElementById(
                "PlanStartDate"
            ).value =
                start.toISOString().split('T')[0];

            document.getElementById(
                "PlanEndDate"
            ).value =
                end.toISOString().split('T')[0];
        }

        plan?.addEventListener(
            "change",
            calculateDates);

        join?.addEventListener(
            "change",
            calculateDates);
    });

</script>