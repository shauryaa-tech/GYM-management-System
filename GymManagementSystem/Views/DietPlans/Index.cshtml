@model List<GymManagement.Models.DietPlan>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Diet Plans";

    int totalPlans = Model.Count;
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }
    .stats-card:hover {
        transform: translateY(-5px);
    }
    .form-control, .form-select { border-radius: 10px; }
    .btn { border-radius: 10px; }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">Diet Plans</h2>
            <p class="mb-0">Create and manage nutrition plans for members</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "DietPlans" })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(Context, PermissionRepo, "DietPlans"))
            {
                <button class="btn btn-light btn-lg" data-bs-toggle="collapse" data-bs-target="#planForm">
                    <i class="fas fa-plus me-2"></i>Create Plan
                </button>
            }
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body">
                <h6>Total Diet Plans</h6>
                <h2>@totalPlans</h2>
            </div>
        </div>
    </div>
</div>

<div class="collapse mb-4" id="planForm">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">New Diet Plan</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Save">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label>Member</label>
                        <select name="MemberId" class="form-select" required>
                            <option value="">Select Member</option>
                            @foreach (var m in ViewBag.Members)
                            {
                                <option value="@m.MemberId">@m.MemberCode - @m.MemberName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Plan Name</label>
                        <input type="text" name="PlanName" class="form-control" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Start Date</label>
                        <input type="date" name="StartDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>End Date</label>
                        <input type="date" name="EndDate" class="form-control" value="@DateTime.Today.AddMonths(1).ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Calorie Target</label>
                        <input type="number" name="CalorieTarget" class="form-control" step="0.01" />
                    </div>
                    <div class="col-md-12 mb-3">
                        <label>Remarks</label>
                        <input type="text" name="Remarks" class="form-control" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-2"></i>Save Plan
                </button>
            </form>
        </div>
    </div>
</div>

<!-- SEARCH -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row">
                <div class="col-md-8">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search Plan Name, Member Name..." />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary">Search</button>
                    <a asp-action="Index" class="btn btn-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card shadow border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Plans List (@Model.Count)</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Member Code</th>
                        <th>Member Name</th>
                        <th>Plan Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Calorie Target</th>
                        <th width="150">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MemberCode</td>
                                <td>@item.MemberName</td>
                                <td><span class="fw-bold">@item.PlanName</span></td>
                                <td>@item.StartDate.ToString("dd-MMM-yyyy")</td>
                                <td>@item.EndDate.ToString("dd-MMM-yyyy")</td>
                                <td>@(item.CalorieTarget?.ToString("N0") ?? "-")</td>
                                <td>
                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(Context, PermissionRepo, "DietPlans"))
                                    {
                                        <button class="btn btn-warning btn-sm" onclick="loadPlan(@item.DietPlanId)">Edit</button>
                                    }
                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(Context, PermissionRepo, "DietPlans"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.DietPlanId" class="btn btn-danger btn-sm" onclick="return confirm('Delete Plan?')">Delete</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">No Diet Plans Found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editPlanModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Edit Diet Plan</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editPlanContainer">
            </div>
        </div>
    </div>
</div>

<script>
    function loadPlan(id) {
        fetch('/DietPlans/Edit/' + id)
        .then(response => response.text())
        .then(html => {
            document.getElementById('editPlanContainer').innerHTML = html;
            new bootstrap.Modal(document.getElementById('editPlanModal')).show();
        });
    }
</script>
