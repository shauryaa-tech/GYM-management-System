@model GymManagement.Models.SalaryProcessing

@{
    var monthNames = new Dictionary<int, string>
    {
        { 1, "January" }, { 2, "February" }, { 3, "March" }, { 4, "April" },
        { 5, "May" }, { 6, "June" }, { 7, "July" }, { 8, "August" },
        { 9, "September" }, { 10, "October" }, { 11, "November" }, { 12, "December" }
    };
}

<form method="post" asp-action="Update">
    <input type="hidden" name="SalaryId" value="@Model.SalaryId" />
    @if (Model.IsPaid)
    {
        <div class="alert alert-success py-2 small">
            <i class="fas fa-check-circle me-1"></i> Payment Status: <strong>Paid</strong>
            @if (Model.PaidDate.HasValue)
            {
                <span>— @Model.PaidDate.Value.ToString("dd MMM yyyy")</span>
            }
        </div>
    }
    else if (Model.IsPaymentPending)
    {
        <div class="alert alert-warning py-2 small">
            <i class="fas fa-clock me-1"></i> Payment Status: <strong>Pending</strong> — payment abhi complete nahi hui.
        </div>
    }
    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Staff</label>
            <select name="StaffId" class="form-select" required id="editStaffSelect">
                <option value="">Select Staff</option>
                @foreach (var staff in ViewBag.Staff)
                {
                    if (staff.StaffId == Model.StaffId)
                    {
                        <option value="@staff.StaffId" selected data-salary="@staff.Salary">@staff.StaffName - @staff.Designation</option>
                    }
                    else
                    {
                        <option value="@staff.StaffId" data-salary="@staff.Salary">@staff.StaffName - @staff.Designation</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3 mb-3">
            <label>Month</label>
            <select name="Month" class="form-select" required>
                @for (int m = 1; m <= 12; m++)
                {
                    if (Model.Month == m)
                    {
                        <option value="@m" selected>@monthNames[m]</option>
                    }
                    else
                    {
                        <option value="@m">@monthNames[m]</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3 mb-3">
            <label>Year</label>
            <input type="number" name="Year" class="form-control" value="@Model.Year" min="2020" max="2099" required />
        </div>
        <div class="col-md-4 mb-3">
            <label>Basic Salary (₹)</label>
            <input type="number" step="0.01" min="0" name="BasicSalary" class="form-control" id="editBasicSalaryInput" value="@Model.BasicSalary.ToString("0.00")" required />
        </div>
        <div class="col-md-4 mb-3">
            <label>Deductions (₹)</label>
            <input type="number" step="0.01" min="0" name="Deductions" class="form-control" id="editDeductionsInput" value="@Model.Deductions.ToString("0.00")" />
        </div>
        <div class="col-md-4 mb-3">
            <label>Net Salary (₹)</label>
            <input type="number" step="0.01" min="0" name="NetSalary" class="form-control" id="editNetSalaryInput" value="@Model.NetSalary.ToString("0.00")" />
        </div>
        <div class="col-md-6 mb-3">
            <label>Paid Date</label>
            <input type="date" name="PaidDate" class="form-control" value="@Model.PaidDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-6 mb-3">
            <label>Payment Mode</label>
            <select name="PaymentMode" class="form-select" required>
                @{
                    var modes = Model.IsPaymentPending
                        ? new[] { "Pending", "Cash", "Card", "UPI", "Bank" }
                        : new[] { "Cash", "Card", "UPI", "Bank" };
                    foreach (var mode in modes)
                    {
                        if (Model.PaymentMode == mode)
                        {
                            <option value="@mode" selected>@mode</option>
                        }
                        else
                        {
                            <option value="@mode">@mode</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-12 mb-3">
            <label>Remarks</label>
            <textarea name="Remarks" class="form-control" rows="2">@Model.Remarks</textarea>
        </div>
    </div>
    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-warning">
            <i class="fas fa-save me-2"></i>Update Salary
        </button>
    </div>
</form>

<script>
    function calculateEditNetSalary() {
        var basic = parseFloat(document.getElementById('editBasicSalaryInput').value) || 0;
        var deductions = parseFloat(document.getElementById('editDeductionsInput').value) || 0;
        document.getElementById('editNetSalaryInput').value = (basic - deductions).toFixed(2);
    }

    document.getElementById('editStaffSelect').addEventListener('change', function() {
        var selectedOption = this.options[this.selectedIndex];
        var salary = selectedOption.getAttribute('data-salary');
        if (salary) {
            document.getElementById('editBasicSalaryInput').value = salary;
            calculateEditNetSalary();
        }
    });

    document.getElementById('editBasicSalaryInput').addEventListener('input', calculateEditNetSalary);
    document.getElementById('editDeductionsInput').addEventListener('input', calculateEditNetSalary);
</script>
