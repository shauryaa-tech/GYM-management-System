@model List<GymManagement.Models.ExpenseHeadMaster>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Expense Head Master";

    int totalHeads = Model.Count;
    int activeHeads = Model.Count(x => x.IsActive);
    int inactiveHeads = Model.Count(x => !x.IsActive);
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }
    .stats-card:hover {
        transform: translateY(-5px);
    }
    .form-control, .form-select { border-radius: 10px; }
    .btn { border-radius: 10px; }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">Expense Head Master</h2>
            <p class="mb-0">Manage expense categories</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "ExpenseHeads", allowImport = true })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "ExpenseHeads"))
            {
                <button class="btn btn-light btn-lg"
                        data-bs-toggle="collapse"
                        data-bs-target="#expenseHeadForm">

                    <i class="fas fa-plus me-2"></i>
                    Add Category

                </button>
            }
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body">
                <h6>Total Categories</h6>
                <h2>@totalHeads</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stats-card bg-success text-white">
            <div class="card-body">
                <h6>Active</h6>
                <h2>@activeHeads</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stats-card bg-dark text-white">
            <div class="card-body">
                <h6>Inactive</h6>
                <h2>@inactiveHeads</h2>
            </div>
        </div>
    </div>
</div>

<div class="collapse mb-4" id="expenseHeadForm">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Expense Head</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Save">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label>Category Name</label>
                        <input type="text" name="HeadName" class="form-control" required />
                    </div>
                    <div class="col-md-8 mb-3">
                        <label>Description</label>
                        <input type="text" name="Description" class="form-control" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-2"></i>Save Category
                </button>
            </form>
        </div>
    </div>
</div>

<!-- SEARCH -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row">
                <div class="col-md-8">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search Name, Description..." />
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary">Search</button>
                    <a asp-action="Index" class="btn btn-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card shadow border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Categories List (@Model.Count)</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.HeadName</td>
                                <td>@item.Description</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                Context,
                                                                PermissionRepo,
                                                                "ExpenseHeads"))
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                onclick="loadExpenseHead(@item.ExpenseHeadId)">

                                            Edit

                                        </button>
                                    }
                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                Context,
                                                                PermissionRepo,
                                                                "ExpenseHeads"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.ExpenseHeadId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete Category?')">

                                            Delete

                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">No Categories Found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editExpenseHeadModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Edit Expense Head</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editExpenseHeadContainer">
            </div>
        </div>
    </div>
</div>

<script>
    function loadExpenseHead(id) {
        fetch('/ExpenseHeads/Edit/' + id)
        .then(response => response.text())
        .then(html => {
            document.getElementById('editExpenseHeadContainer').innerHTML = html;
            new bootstrap.Modal(document.getElementById('editExpenseHeadModal')).show();
        });
    }
</script>
