@model GymManagement.Models.WorkoutPlan

<form method="post" asp-action="Update">
    <input type="hidden" asp-for="PlanId" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Member</label>
            <select asp-for="MemberId" class="form-select" required>
                <option value="">Select Member</option>
                @foreach (var m in ViewBag.Members)
                {
                    <option value="@m.MemberId">@m.MemberCode - @m.MemberName</option>
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Plan Name</label>
            <input asp-for="PlanName" class="form-control" required />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" required />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" required />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Goals</label>
            <input asp-for="Goals" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Trainer</label>
            <select asp-for="TrainerId" class="form-select">
                <option value="">No Trainer</option>
                @foreach (var t in ViewBag.Trainers)
                {
                    <option value="@t.StaffId">@t.StaffName</option>
                }
            </select>
        </div>
        <div class="col-md-12 mb-3">
            <label class="form-label">Remarks</label>
            <input asp-for="Remarks" class="form-control" />
        </div>
    </div>
    <div class="text-end">
        <button type="submit" class="btn btn-success">
            <i class="fas fa-save me-2"></i>Update Plan
        </button>
    </div>
</form>
