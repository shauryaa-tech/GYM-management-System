@model GymManagement.ViewModels.UsersRolesViewModel
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo
@using GymManagement.Models

@{
    ViewData["Title"] = "User & Role Master";
    string activeTab = ViewBag.ActiveTab ?? "users";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }

    .stats-card:hover {
        transform: translateY(-5px);
    }

    .form-control,
    .form-select {
        border-radius: 10px;
    }

    .btn {
        border-radius: 10px;
    }

    .nav-tabs .nav-link {
        color: #555;
        font-weight: 600;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 12px 20px;
    }

    .nav-tabs .nav-link.active {
        color: #2563eb;
        border: none;
        border-bottom: 3px solid #2563eb;
        background: transparent;
        font-weight: bold;
    }

    .user-avatar {
        width: 45px;
        height: 45px;
        object-fit: cover;
        border-radius: 50%;
        border: 2px solid #e2e8f0;
    }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">User & Role Master</h2>
            <p class="mb-0">Manage system users, roles, and access permissions</p>
        </div>
        <div>
            @if (activeTab == "users")
            {
                @if (GymManagement.Helpers.PermissionHelper.CanAdd(Context, PermissionRepo, "UsersRoles"))
                {
                    <button class="btn btn-light btn-lg" data-bs-toggle="modal" data-bs-target="#addUserModal">
                        <i class="fas fa-user-plus me-2"></i>Add New User
                    </button>
                }
            }
            else
            {
                @if (GymManagement.Helpers.PermissionHelper.CanAdd(Context, PermissionRepo, "UsersRoles"))
                {
                    <button class="btn btn-light btn-lg" data-bs-toggle="modal" data-bs-target="#addRoleModal">
                        <i class="fas fa-plus me-2"></i>Add New Role
                    </button>
                }
            }
        </div>
    </div>
</div>

<!-- TABS NAVIGATION -->
<ul class="nav nav-tabs mb-4 border-bottom-0" id="userRoleTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "users" ? "active" : "")" 
                id="users-tab" 
                data-bs-toggle="tab" 
                data-bs-target="#users-content" 
                type="button" 
                role="tab" 
                onclick="updateTabParam('users')">
            <i class="fas fa-users me-2"></i>Users List
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(activeTab == "roles" ? "active" : "")" 
                id="roles-tab" 
                data-bs-toggle="tab" 
                data-bs-target="#roles-content" 
                type="button" 
                role="tab" 
                onclick="updateTabParam('roles')">
            <i class="fas fa-user-shield me-2"></i>Roles & Permissions
        </button>
    </li>
</ul>

<!-- TABS CONTENT -->
<div class="tab-content" id="userRoleTabsContent">
    
    <!-- USERS TAB -->
    <div class="tab-pane fade @(activeTab == "users" ? "show active" : "")" id="users-content" role="tabpanel">
        <!-- SEARCH -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <form method="get" asp-action="Index">
                    <input type="hidden" name="tab" value="users" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by Full Name or Username..." />
                        </div>
                        <div class="col-md-4">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-search me-2"></i>Search
                            </button>
                            <a asp-action="Index" asp-route-tab="users" class="btn btn-secondary px-4">Reset</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- USERS TABLE -->
        <div class="card shadow border-0">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="fas fa-users me-2"></i>System Users (@Model.Users.Count)</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Photo</th>
                                <th>Full Name</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th width="180">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Users.Count > 0)
                            {
                                @foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td>
                                            <img src="@(string.IsNullOrEmpty(user.ProfilePhoto) ? "/uploads/Profiles/default-user.jpg" : user.ProfilePhoto)" 
                                                 class="user-avatar" 
                                                 alt="Avatar" 
                                                 onerror="this.src='/uploads/Profiles/default-user.jpg'" />
                                        </td>
                                        <td class="fw-bold">@user.FullName</td>
                                        <td>@user.UserName</td>
                                        <td>@user.Email</td>
                                        <td>
                                            <span class="badge bg-primary text-uppercase px-2 py-1">@user.RoleName</span>
                                        </td>
                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            @if (GymManagement.Helpers.PermissionHelper.CanEdit(Context, PermissionRepo, "UsersRoles"))
                                            {
                                                <button class="btn btn-warning btn-sm" onclick="loadUser(@user.UserId)">
                                                    <i class="fas fa-edit"></i> Edit
                                                </button>
                                            }
                                            @if (GymManagement.Helpers.PermissionHelper.CanDelete(Context, PermissionRepo, "UsersRoles"))
                                            {
                                                <a asp-action="DeleteUser" asp-route-id="@user.UserId" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this user?')">
                                                    <i class="fas fa-trash"></i> Delete
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">No Users Found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ROLES TAB -->
    <div class="tab-pane fade @(activeTab == "roles" ? "show active" : "")" id="roles-content" role="tabpanel">
        <div class="card shadow border-0">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="fas fa-user-shield me-2"></i>Roles List (@Model.Roles.Count)</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Role Name</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th width="280">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Roles.Count > 0)
                            {
                                @foreach (var role in Model.Roles)
                                {
                                    <tr>
                                        <td class="fw-bold text-primary">@role.RoleName</td>
                                        <td>@role.Description</td>
                                        <td>
                                            @if (role.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="Permissions" asp-route-id="@role.RoleId" class="btn btn-info btn-sm text-white">
                                                <i class="fas fa-lock me-1"></i> Permissions
                                            </a>
                                            @if (GymManagement.Helpers.PermissionHelper.CanEdit(Context, PermissionRepo, "UsersRoles"))
                                            {
                                                <button class="btn btn-warning btn-sm" onclick="loadRole(@role.RoleId)">
                                                    <i class="fas fa-edit"></i> Edit
                                                </button>
                                            }
                                            @if (GymManagement.Helpers.PermissionHelper.CanDelete(Context, PermissionRepo, "UsersRoles"))
                                            {
                                                <a asp-action="DeleteRole" asp-route-id="@role.RoleId" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this role?')">
                                                    <i class="fas fa-trash"></i> Delete
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">No Roles Found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ADD USER MODAL -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-user-plus me-2"></i>Add New User</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="SaveUser" method="post" enctype="multipart/form-data">
                    <div class="text-center mb-3">
                        <img id="addPreviewImage" src="/uploads/Profiles/default-user.jpg" class="rounded-circle border" width="120" height="120" style="object-fit:cover;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Profile Photo</label>
                        <input type="file" name="photo" class="form-control" accept="image/*" onchange="previewAddPhoto(this)" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Full Name</label>
                            <input type="text" name="FullName" class="form-control" placeholder="Enter Full Name" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Username</label>
                            <input type="text" name="UserName" class="form-control" placeholder="Enter Username" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Email Address</label>
                            <input type="email" name="Email" class="form-control" placeholder="Enter Email" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Password</label>
                            <input type="password" name="PasswordHash" class="form-control" placeholder="Enter Password" required />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Role</label>
                            <select name="RoleId" class="form-select" required>
                                <option value="">-- Select Role --</option>
                                @foreach (var role in ViewBag.Roles)
                                {
                                    <option value="@role.RoleId">@role.RoleName</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="text-end mt-3">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fas fa-save me-2"></i>Save User
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ADD ROLE MODAL -->
<div class="modal fade" id="addRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-plus me-2"></i>Add New Role</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="SaveRole" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Role Name</label>
                        <input type="text" name="RoleName" class="form-control" placeholder="Enter Role Name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="Description" class="form-control" rows="3" placeholder="Enter Description"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Status</label>
                        <select name="IsActive" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                    <div class="text-end mt-3">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="fas fa-save me-2"></i>Save Role
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- EDIT USER MODAL -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="fas fa-user-edit me-2"></i>Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="editUserContainer">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

<!-- EDIT ROLE MODAL -->
<div class="modal fade" id="editRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Edit Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="editRoleContainer">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@Html.Raw(TempData["Success"])'
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@Html.Raw(TempData["Error"])'
            });
        </script>
    }

    <script>
        function updateTabParam(tabName) {
            const url = new URL(window.location.href);
            url.searchParams.set('tab', tabName);
            window.history.pushState({}, '', url);
            
            // Toggle add button in header
            const headerBtnContainer = document.querySelector('.page-header .btn-light').parentElement;
            if (tabName === 'users') {
                headerBtnContainer.innerHTML = `
                    @if (GymManagement.Helpers.PermissionHelper.CanAdd(Context, PermissionRepo, "UsersRoles"))
                    {
                        <button class="btn btn-light btn-lg" data-bs-toggle="modal" data-bs-target="#addUserModal">
                            <i class="fas fa-user-plus me-2"></i>Add New User
                        </button>
                    }
                `;
            } else {
                headerBtnContainer.innerHTML = `
                    @if (GymManagement.Helpers.PermissionHelper.CanAdd(Context, PermissionRepo, "UsersRoles"))
                    {
                        <button class="btn btn-light btn-lg" data-bs-toggle="modal" data-bs-target="#addRoleModal">
                            <i class="fas fa-plus me-2"></i>Add New Role
                        </button>
                    }
                `;
            }
        }

        function previewAddPhoto(input) {
            if (input.files && input.files[0]) {
                let reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById("addPreviewImage").src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function loadUser(id) {
            fetch('/UsersRoles/EditUser/' + id)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('editUserContainer').innerHTML = html;
                    new bootstrap.Modal(document.getElementById('editUserModal')).show();
                })
                .catch(err => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to load user details'
                    });
                });
        }

        function loadRole(id) {
            fetch('/UsersRoles/EditRole/' + id)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('editRoleContainer').innerHTML = html;
                    new bootstrap.Modal(document.getElementById('editRoleModal')).show();
                })
                .catch(err => {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to load role details'
                    });
                });
        }
    </script>
}