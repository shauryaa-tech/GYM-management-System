@model List<GymManagement.Models.StaffMaster>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Staff Master";

    int totalStaff = Model.Count;
    int activeStaff = Model.Count(x => x.IsActive);
    int inactiveStaff = Model.Count(x => !x.IsActive);
    int trainers = Model.Count(x => x.RoleName == "Trainer");
}

<style>

    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }

    .stats-card:hover {
        transform: translateY(-5px);
    }

    .form-control,
    .form-select {
        border-radius: 12px;
    }

    .btn {
        border-radius: 10px;
    }

</style>

<div class="page-header">

    <div class="d-flex justify-content-between align-items-center">

        <div>

            <h2 class="fw-bold mb-1">
                Staff Master
            </h2>

            <p class="mb-0">
                Manage Trainers, Receptionists and Staff
            </p>

        </div>

        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "StaffMaster", allowImport = true })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "StaffMaster"))
            {
                <button class="btn btn-light btn-lg"
                        data-bs-toggle="collapse"
                        data-bs-target="#staffForm">

                    <i class="fas fa-plus me-2"></i>
                    Add Staff

                </button>
            }
        </div>

    </div>

</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="row mb-4">

    <div class="col-md-3">

        <div class="card stats-card bg-primary text-white">

            <div class="card-body">

                <h6>Total Staff</h6>

                <h2>@totalStaff</h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card stats-card bg-success text-white">

            <div class="card-body">

                <h6>Active Staff</h6>

                <h2>@activeStaff</h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card stats-card bg-danger text-white">

            <div class="card-body">

                <h6>Inactive Staff</h6>

                <h2>@inactiveStaff</h2>

            </div>

        </div>

    </div>

    <div class="col-md-3">

        <div class="card stats-card bg-dark text-white">

            <div class="card-body">

                <h6>Trainers</h6>

                <h2>@trainers</h2>

            </div>

        </div>

    </div>

</div>

<div class="collapse mb-4"
     id="staffForm">

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">
                Add New Staff
            </h5>

        </div>

        <div class="card-body">

            <form method="post"
                  asp-action="Save">

                <div class="row">

                    <div class="col-md-4 mb-3">

                        <label>
                            Staff Code <small class="text-muted">(unique — biometric)</small>
                        </label>

                        <input type="text"
                               name="StaffCode"
                               class="form-control text-uppercase"
                               placeholder="e.g. EMP043 (auto if blank)"
                               maxlength="20" />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>
                            Staff Name
                        </label>

                        <input type="text"
                               name="StaffName"
                               class="form-control"
                               required />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>
                            Mobile Number
                        </label>

                        <input type="text"
                               name="MobileNo"
                               class="form-control"
                               required />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>
                            Email
                        </label>

                        <input type="email"
                               name="Email"
                               class="form-control" />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>
                            Gender
                        </label>

                        <select name="Gender"
                                class="form-select">

                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>

                        </select>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>
                            Role
                        </label>

                        <select name="RoleId"
                                class="form-select">

                            @foreach(var role in ViewBag.Roles)
                            {
                                <option value="@role.RoleId">
                                    @role.RoleName
                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>
                            Salary
                        </label>

                        <input type="number"
                               min="0"
                               step="0.01"
                               name="Salary"
                               class="form-control" />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>
                            Joining Date
                        </label>

                        <input type="date"
                               name="JoiningDate"
                               class="form-control"
                               value="@DateTime.Now.ToString("yyyy-MM-dd")" />

                    </div>

                    <div class="col-md-4 mb-3">

                        <label>
                            Status
                        </label>

                        <select name="IsActive"
                                class="form-select">

                            <option value="true">
                                Active
                            </option>

                            <option value="false">
                                Inactive
                            </option>

                        </select>

                    </div>

                    <div class="col-md-8 mb-3">
                        <label>Trainer Experience Areas</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var interest in GymManagement.Helpers.TrainerInterestOptions.All)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="SpecializationOptions" value="@interest" id="spec_@interest.Replace(" ", "")" />
                                    <label class="form-check-label" for="spec_@interest.Replace(" ", "")">@interest</label>
                                </div>
                            }
                        </div>
                        <small class="text-muted">Member interest ke basis par auto-assign ke liye</small>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Experience (Years)</label>
                        <input type="number" min="0" name="ExperienceYears" class="form-control" placeholder="e.g. 5" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Bank Name</label>
                        <input type="text" name="BankName" class="form-control" placeholder="e.g. SBI" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Bank Account No</label>
                        <input type="text" name="BankAccountNo" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>IFSC Code</label>
                        <input type="text" name="IfscCode" class="form-control text-uppercase" maxlength="20" />
                    </div>

                    <div class="col-md-12 mb-3">

                        <label>
                            Address
                        </label>

                        <textarea name="Address"
                                  rows="3"
                                  class="form-control"></textarea>

                    </div>

                </div>

                <button type="submit"
                        class="btn btn-success">

                    <i class="fas fa-save me-2"></i>
                    Save Staff

                </button>

            </form>

        </div>

    </div>

</div>

<!-- STAFF TABLE -->

<div class="card shadow border-0">

    <div class="card-header bg-dark text-white">

        <h5 class="mb-0">

            Staff Members (@Model.Count)

        </h5>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-light">

                    <tr>

                        <th>Staff Code</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Mobile</th>
                        <th>Bank A/c</th>
                        <th>Salary</th>
                        <th>Status</th>
                        <th width="180">Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <span class="badge bg-dark">@item.DisplayStaffCode</span>
                                </td>

                                <td>
                                    @item.StaffName
                                </td>

                                <td>

                                    @if (item.RoleName == "Trainer")
                                    {
                                        <span class="badge bg-primary">
                                            Trainer
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            @item.RoleName
                                        </span>
                                    }

                                </td>

                                <td>
                                    @item.MobileNo
                                </td>

                                <td class="small">
                                    @(string.IsNullOrWhiteSpace(item.BankAccountNo) ? "—" : item.BankAccountNo)
                                </td>

                                <td>
                                    ₹@item.Salary.ToString("N0")
                                </td>

                                <td>

                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            Inactive
                                        </span>
                                    }

                                </td>

                                <td>

                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                Context,
                                                                PermissionRepo,
                                                                "StaffMaster"))
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                onclick="loadStaff(@item.StaffId)">

                                            Edit

                                        </button>
                                    }

                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                Context,
                                                                PermissionRepo,
                                                                "StaffMaster"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.StaffId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete Staff?')">

                                            Delete

                                        </a>
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="9"
                                class="text-center text-muted">

                                No Staff Found

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<!-- EDIT MODAL -->

<div class="modal fade"
     id="editStaffModal">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header bg-warning">

                <h5 class="modal-title">

                    Edit Staff

                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body"
                 id="editStaffContainer">
            </div>

        </div>

    </div>

</div>

<script>

    function loadStaff(id)
    {
        fetch('/StaffMasters/Edit/' + id)
        .then(response => response.text())
        .then(html =>
        {
            document.getElementById(
                'editStaffContainer'
            ).innerHTML = html;

            new bootstrap.Modal(
                document.getElementById(
                    'editStaffModal'
                )
            ).show();
        });
    }

</script>