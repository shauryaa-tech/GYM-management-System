@model GymManagement.ViewModels.PaymentGatewayListViewModel
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Payment Gateway";
    var total = Model.Gateways.Count;
    var active = Model.Gateways.Count(x => x.IsActive);
    var validated = Model.Gateways.Count(x => x.IsValidated);
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .stats-card { border: none; border-radius: 18px; transition: .3s; }
    .stats-card:hover { transform: translateY(-5px); }
    .form-control, .form-select, .btn { border-radius: 10px; }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">Payment Gateway</h2>
            <p class="mb-0">Configure online payment providers for memberships, PT, classes, and products</p>
        </div>
        @if (GymManagement.Helpers.PermissionHelper.CanAdd(Context, PermissionRepo, "PaymentGateway"))
        {
            <a asp-action="Create" class="btn btn-light btn-lg">
                <i class="fa-solid fa-plus me-2"></i>Add Gateway
            </a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body"><h6>Total Gateways</h6><h2>@total</h2></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stats-card bg-success text-white">
            <div class="card-body"><h6>Active</h6><h2>@active</h2></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stats-card bg-info text-white">
            <div class="card-body"><h6>Validated</h6><h2>@validated</h2></div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search gateway, display name, MID..." />
            </div>
            <div class="col-md-3">
                <select name="environment" class="form-select">
                    <option value="">All Environments</option>
                    <option value="Sandbox" selected="@(Model.EnvironmentFilter == "Sandbox")">Sandbox</option>
                    <option value="Production" selected="@(Model.EnvironmentFilter == "Production")">Production</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">All Status</option>
                    <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
                    <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Configured Gateways (@Model.Gateways.Count)</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Gateway</th>
                        <th>Display Name</th>
                        <th>Environment</th>
                        <th>Validated</th>
                        <th>Default</th>
                        <th>Status</th>
                        <th>Last Validation</th>
                        <th width="260">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Gateways.Any())
                    {
                        foreach (var item in Model.Gateways)
                        {
                            <tr>
                                <td><span class="badge bg-primary">@item.GatewayName</span></td>
                                <td class="fw-semibold">@item.DisplayName</td>
                                <td>
                                    @if (item.Environment == "Production")
                                    {
                                        <span class="badge bg-danger">Production</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Sandbox</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsValidated)
                                    {
                                        <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i>Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">No</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsDefault)
                                    {
                                        <span class="badge bg-info">Default</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark">Inactive</span>
                                    }
                                </td>
                                <td>@(item.LastValidatedOn?.ToLocalTime().ToString("dd-MMM-yyyy HH:mm") ?? "-")</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @if (GymManagement.Helpers.PermissionHelper.CanEdit(Context, PermissionRepo, "PaymentGateway"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                                            if (!item.IsDefault && item.IsValidated)
                                            {
                                                <a asp-action="SetDefault" asp-route-id="@item.Id" class="btn btn-info btn-sm">Set Default</a>
                                            }
                                            if (item.IsActive)
                                            {
                                                <a asp-action="Deactivate" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">Deactivate</a>
                                            }
                                            else
                                            {
                                                <a asp-action="Activate" asp-route-id="@item.Id" class="btn btn-success btn-sm">Activate</a>
                                            }
                                        }
                                        @if (GymManagement.Helpers.PermissionHelper.CanDelete(Context, PermissionRepo, "PaymentGateway"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Delete this payment gateway?')">Delete</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No payment gateways configured yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
