@using GymManagement.Services.WhatsApp
@{
    ViewData["Title"] = "WhatsApp Bot";
    var formUrl = ViewBag.FormUrl as string ?? string.Empty;
    var webhookUrl = ViewBag.WebhookUrl as string ?? string.Empty;
    var shareUrl = ViewBag.WhatsAppShareUrl as string ?? string.Empty;
    var settings = ViewBag.Settings as WhatsAppSettings;
    var isConfigured = ViewBag.IsConfigured as bool? ?? false;
}

<style>
    .setup-card {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 8px 30px rgba(15, 23, 42, .08);
    }
    .copy-box {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        border-radius: 12px;
        padding: 12px;
        word-break: break-all;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">WhatsApp Bot</h2>
        <p class="text-muted mb-0">Share join form link with users. After form submit they continue on WhatsApp bot.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card setup-card">
            <div class="card-body p-4">
                <h5 class="fw-bold">Public Join Form Link</h5>
                <p class="text-muted">Admin is link ko WhatsApp par users ko bhejein.</p>
                <div class="copy-box mb-3" id="formUrlBox">@formUrl</div>
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="btn btn-primary" onclick="copyText('formUrlBox')">
                        <i class="fa fa-copy me-2"></i>Copy Form Link
                    </button>
                    <a href="@shareUrl" target="_blank" class="btn btn-success">
                        <i class="fa-brands fa-whatsapp me-2"></i>Share on WhatsApp
                    </a>
                    <a href="@formUrl" target="_blank" class="btn btn-outline-secondary">Preview Form</a>
                </div>
            </div>
        </div>

        <div class="card setup-card mt-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">User Flow</h5>
                <ol class="mb-0">
                    <li>User form link par click karke details fill karega → naya lead banega</li>
                    <li>WhatsApp bot par trainer select karega</li>
                    <li>Class select karega</li>
                    <li>Membership plan select karega</li>
                    <li>Pay Now link par click karke online payment karega</li>
                </ol>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card setup-card">
            <div class="card-body p-4">
                <h5 class="fw-bold">API Status</h5>
                <p class="small text-muted">
                    SmartPing credentials configure karein:
                    <a asp-controller="WhatsAppApiSetup" asp-action="Index">WhatsApp API Setup</a>
                </p>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Webhook URL</label>
                    <div class="copy-box" id="webhookBox">@webhookUrl</div>
                    <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="copyText('webhookBox')">Copy Webhook</button>
                </div>

                <ul class="small mb-0">
                    <li><strong>Status:</strong> @(isConfigured ? "Configured" : "Not configured")</li>
                    <li><strong>Enabled:</strong> @(settings?.Enabled == true ? "Yes" : "No")</li>
                    <li><strong>Phone Number ID:</strong> @(string.IsNullOrWhiteSpace(settings?.PhoneNumberId) ? "Not set" : settings!.PhoneNumberId)</li>
                    <li><strong>Business Phone:</strong> @(string.IsNullOrWhiteSpace(settings?.BusinessPhone) ? "Not set" : settings!.BusinessPhone)</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function copyText(id) {
            const text = document.getElementById(id)?.innerText || '';
            navigator.clipboard.writeText(text);
        }
    </script>
}
