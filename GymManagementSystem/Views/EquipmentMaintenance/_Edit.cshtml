@model GymManagement.Models.EquipmentMaintenance

<form method="post" asp-action="Update" id="editMaintenanceForm">
    <input type="hidden" name="MaintenanceId" value="@Model.MaintenanceId" />
    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Equipment</label>
            <select name="EquipmentId" class="form-select" required>
                <option value="">Select Equipment</option>
                @foreach (var eq in ViewBag.Equipment)
                {
                    if (eq.EquipmentId == Model.EquipmentId)
                    {
                        <option value="@eq.EquipmentId" selected>@eq.EquipmentName (@eq.Category)</option>
                    }
                    else
                    {
                        <option value="@eq.EquipmentId">@eq.EquipmentName (@eq.Category)</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Maintenance Date</label>
            <input type="date" name="MaintenanceDate" class="form-control" required value="@Model.MaintenanceDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-6 mb-3">
            <label>Maintenance Type</label>
            <select name="MaintenanceType" class="form-select" required>
                @{
                    var types = new[] { "Preventive", "Corrective", "AMC", "Inspection", "Repair" };
                    foreach (var t in types)
                    {
                        if (Model.MaintenanceType == t)
                        {
                            <option value="@t" selected>@t</option>
                        }
                        else
                        {
                            <option value="@t">@t</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Cost (₹)</label>
            <input type="number" step="0.01" min="0" name="Cost" class="form-control" required value="@Model.Cost.ToString("0.00")" />
        </div>
        <div class="col-md-4 mb-3">
            <label>Payment Mode</label>
            <select name="PaymentMode" class="form-select">
                <option value="">None</option>
                @if (Model.PaymentMode == "Cash") { <option value="Cash" selected>Cash</option> } else { <option value="Cash">Cash</option> }
                @if (Model.PaymentMode == "Card") { <option value="Card" selected>Card</option> } else { <option value="Card">Card</option> }
                @if (Model.PaymentMode == "UPI") { <option value="UPI" selected>UPI</option> } else { <option value="UPI">UPI</option> }
                @if (Model.PaymentMode == "Bank") { <option value="Bank" selected>Bank Transfer</option> } else { <option value="Bank">Bank Transfer</option> }
            </select>
        </div>
        <div class="col-md-4 mb-3">
            <label>Vendor Name</label>
            <input type="text" name="VendorName" class="form-control" value="@Model.VendorName" />
        </div>
        <div class="col-md-4 mb-3">
            <label>Next Due Date</label>
            <input type="date" name="NextDueDate" class="form-control" value="@Model.NextDueDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-4 mb-3">
            <label>Status</label>
            <select name="Status" class="form-select" required>
                @{
                    var statuses = new[] { "Completed", "Scheduled", "Pending", "Cancelled" };
                    foreach (var s in statuses)
                    {
                        if (Model.Status == s)
                        {
                            <option value="@s" selected>@s</option>
                        }
                        else
                        {
                            <option value="@s">@s</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-8 mb-3">
            <label>Remarks</label>
            <textarea name="Remarks" class="form-control" rows="2">@Model.Remarks</textarea>
        </div>
    </div>
    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-warning">
            <i class="fas fa-save me-2"></i>Update Maintenance
        </button>
    </div>
</form>
