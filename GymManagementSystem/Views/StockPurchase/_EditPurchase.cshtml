@model GymManagement.Models.StockPurchase

<form method="post" asp-action="Update" id="editPurchaseForm">
    <input type="hidden" name="PurchaseId" value="@Model.PurchaseId" />
    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Product</label>
            <select name="ProductId" class="form-select" required id="editProductSelect">
                <option value="">Select Product</option>
                @foreach (var product in ViewBag.Products)
                {
                    if (product.ProductId == Model.ProductId)
                    {
                        <option value="@product.ProductId" selected data-price="@product.UnitPrice" data-stock="@product.CurrentStock">@product.ProductName (@product.Category)</option>
                    }
                    else
                    {
                        <option value="@product.ProductId" data-price="@product.UnitPrice" data-stock="@product.CurrentStock">@product.ProductName (@product.Category)</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Vendor</label>
            <select name="VendorId" class="form-select" required>
                <option value="">Select Vendor</option>
                @foreach (var vendor in ViewBag.Vendors)
                {
                    if (vendor.VendorId == Model.VendorId)
                    {
                        <option value="@vendor.VendorId" selected>@vendor.VendorName</option>
                    }
                    else
                    {
                        <option value="@vendor.VendorId">@vendor.VendorName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-4 mb-3">
            <label>Quantity</label>
            <input type="number" min="1" name="Quantity" class="form-control" required id="editQuantityInput" value="@Model.Quantity" />
        </div>
        <div class="col-md-4 mb-3">
            <label>Unit Price (₹)</label>
            <input type="number" step="0.01" min="0" name="UnitPrice" class="form-control" required id="editUnitPriceInput" value="@Model.UnitPrice.ToString("0.00")" />
        </div>
        <div class="col-md-4 mb-3">
            <label>Total Amount (₹)</label>
            <input type="number" step="0.01" min="0" name="TotalAmount" class="form-control" required id="editTotalAmountInput" value="@Model.TotalAmount.ToString("0.00")" readonly />
        </div>
        <div class="col-md-4 mb-3">
            <label>Purchase Date</label>
            <input type="date" name="PurchaseDate" class="form-control" required value="@Model.PurchaseDate.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-4 mb-3">
            <label>Invoice No</label>
            <input type="text" name="InvoiceNo" class="form-control" value="@Model.InvoiceNo" />
        </div>
        <div class="col-md-4 mb-3">
            <label>Current Stock (after this purchase)</label>
            <input type="text" class="form-control" id="editCurrentStock" readonly />
        </div>
    </div>
    <div class="row">
        <div class="col-md-12 mb-3">
            <label>Remarks</label>
            <textarea name="Remarks" class="form-control" rows="2">@Model.Remarks</textarea>
        </div>
    </div>
    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-warning">
            <i class="fas fa-save me-2"></i>Update Purchase
        </button>
    </div>
</form>

<script>
    // Auto-calculate total amount
    document.getElementById('editQuantityInput').addEventListener('input', calculateEditTotal);
    document.getElementById('editUnitPriceInput').addEventListener('input', calculateEditTotal);

    function calculateEditTotal() {
        var qty = parseFloat(document.getElementById('editQuantityInput').value) || 0;
        var price = parseFloat(document.getElementById('editUnitPriceInput').value) || 0;
        document.getElementById('editTotalAmountInput').value = (qty * price).toFixed(2);
    }

    // Auto-fill unit price when product changes
    document.getElementById('editProductSelect').addEventListener('change', function() {
        var selectedOption = this.options[this.selectedIndex];
        var price = selectedOption.getAttribute('data-price');
        var stock = selectedOption.getAttribute('data-stock');
        if (price) {
            document.getElementById('editUnitPriceInput').value = price;
            calculateEditTotal();
        }
        if (stock) {
            var currentQty = parseFloat(document.getElementById('editQuantityInput').value) || 0;
            document.getElementById('editCurrentStock').value = (parseInt(stock) + currentQty).toString();
        }
    });

    // Update current stock display when quantity changes
    document.getElementById('editQuantityInput').addEventListener('input', function() {
        var selectedOption = document.getElementById('editProductSelect').options[document.getElementById('editProductSelect').selectedIndex];
        var stock = selectedOption.getAttribute('data-stock');
        if (stock) {
            var currentQty = parseFloat(this.value) || 0;
            document.getElementById('editCurrentStock').value = (parseInt(stock) + currentQty).toString();
        }
    });

    // Initialize current stock on load
    document.addEventListener('DOMContentLoaded', function() {
        var selectedOption = document.getElementById('editProductSelect').options[document.getElementById('editProductSelect').selectedIndex];
        var stock = selectedOption.getAttribute('data-stock');
        if (stock) {
            var currentQty = parseFloat(document.getElementById('editQuantityInput').value) || 0;
            document.getElementById('editCurrentStock').value = (parseInt(stock) + currentQty).toString();
        }
    });
</script>