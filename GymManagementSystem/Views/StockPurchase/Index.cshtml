@model List<GymManagement.Models.StockPurchase>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Stock Purchase";

    int totalPurchases = Model.Count;
    int totalQty = Model.Sum(x => x.Quantity);
    decimal totalAmount = Model.Sum(x => x.TotalAmount);
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }
    .stats-card:hover {
        transform: translateY(-5px);
    }
    .form-control, .form-select { border-radius: 10px; }
    .btn { border-radius: 10px; }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">Stock Purchase</h2>
            <p class="mb-0">Manage product stock purchases</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "StockPurchase" })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "StockPurchase"))
            {
                <button class="btn btn-light btn-lg"
                        data-bs-toggle="collapse"
                        data-bs-target="#purchaseForm">

                    <i class="fas fa-plus me-2"></i>
                    Add Purchase

                </button>
            }
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body">
                <h6>Total Purchases</h6>
                <h2>@totalPurchases</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card bg-success text-white">
            <div class="card-body">
                <h6>Total Quantity</h6>
                <h2>@totalQty</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card bg-info text-white">
            <div class="card-body">
                <h6>Total Amount</h6>
                <h2>@totalAmount.ToString("C0")</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stats-card bg-warning text-white">
            <div class="card-body">
                <h6>Unique Products</h6>
                <h2>@Model.Select(x => x.ProductId).Distinct().Count()</h2>
            </div>
        </div>
    </div>
</div>

<div class="collapse mb-4" id="purchaseForm">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Stock Purchase</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Save" id="purchaseFormElement">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label>Product</label>
                        <select name="ProductId" class="form-select" required id="productSelect">
                            <option value="">Select Product</option>
                            @foreach (var product in ViewBag.Products)
                            {
                                <option value="@product.ProductId" data-price="@product.UnitPrice" data-stock="@product.CurrentStock">@product.ProductName (@product.Category)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Vendor</label>
                        <select name="VendorId" class="form-select" required>
                            <option value="">Select Vendor</option>
                            @foreach (var vendor in ViewBag.Vendors)
                            {
                                <option value="@vendor.VendorId">@vendor.VendorName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2 mb-3">
                        <label>Quantity</label>
                        <input type="number" min="1" name="Quantity" class="form-control" required id="quantityInput" value="1" />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label>Unit Price (₹)</label>
                        <input type="number" step="0.01" min="0" name="UnitPrice" class="form-control" required id="unitPriceInput" readonly />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label>Total Amount (₹)</label>
                        <input type="number" step="0.01" min="0" name="TotalAmount" class="form-control" required id="totalAmountInput" readonly />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label>Purchase Date</label>
                        <input type="date" name="PurchaseDate" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Invoice No</label>
                        <input type="text" name="InvoiceNo" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label>Remarks</label>
                        <input type="text" name="Remarks" class="form-control" placeholder="Optional remarks" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-2"></i>Save Purchase
                </button>
            </form>
        </div>
    </div>
</div>

<!-- SEARCH -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row">
                <div class="col-md-3">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search Product/Invoice..." />
                </div>
                <div class="col-md-2">
                    <select name="productId" class="form-select">
                        <option value="">All Products</option>
                        @foreach (var product in ViewBag.Products)
                        {
                            if (ViewBag.ProductId != null && ViewBag.ProductId.ToString() == product.ProductId.ToString())
                            {
                                <option value="@product.ProductId" selected>@product.ProductName</option>
                            }
                            else
                            {
                                <option value="@product.ProductId">@product.ProductName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="vendorId" class="form-select">
                        <option value="">All Vendors</option>
                        @foreach (var vendor in ViewBag.Vendors)
                        {
                            if (ViewBag.VendorId != null && ViewBag.VendorId.ToString() == vendor.VendorId.ToString())
                            {
                                <option value="@vendor.VendorId" selected>@vendor.VendorName</option>
                            }
                            else
                            {
                                <option value="@vendor.VendorId">@vendor.VendorName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label>From Date</label>
                    <input type="date" name="fromDate" value="@ViewBag.FromDate" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label>To Date</label>
                    <input type="date" name="toDate" value="@ViewBag.ToDate" class="form-control" />
                </div>
                <div class="col-md-1">
                    <label>&nbsp;</label>
                    <button class="btn btn-primary w-100">Search</button>
                </div>
                <div class="col-md-1">
                    <label>&nbsp;</label>
                    <a asp-action="Index" class="btn btn-secondary w-100">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card shadow border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Purchase List (@Model.Count)</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>Vendor</th>
                        <th>Date</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Total</th>
                        <th>Invoice No</th>
                        <th>Remarks</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@item.ProductName</strong><br />
                                    <small class="text-muted">@item.Category</small>
                                </td>
                                <td>@item.VendorName</td>
                                <td>@item.PurchaseDate.ToString("dd MMM yyyy")</td>
                                <td><span class="badge bg-primary">@item.Quantity</span></td>
                                <td>@item.UnitPrice.ToString("C0")</td>
                                <td><strong>@item.TotalAmount.ToString("C0")</strong></td>
                                <td>@item.InvoiceNo</td>
                                <td>@item.Remarks</td>
                                <td>
                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                        Context,
                                                                        PermissionRepo,
                                                                        "StockPurchase"))
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                onclick="loadPurchase(@item.PurchaseId)">

                                            Edit

                                        </button>
                                    }
                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                        Context,
                                                                        PermissionRepo,
                                                                        "StockPurchase"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.PurchaseId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete this purchase? Stock will be reduced.')">

                                            Delete

                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted">No Purchases Found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editPurchaseModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Edit Stock Purchase</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editPurchaseContainer">
            </div>
        </div>
    </div>
</div>

<script>
    // Auto-calculate total amount
    document.getElementById('quantityInput').addEventListener('input', calculateTotal);
    document.getElementById('unitPriceInput').addEventListener('input', calculateTotal);

    function calculateTotal() {
        var qty = parseFloat(document.getElementById('quantityInput').value) || 0;
        var price = parseFloat(document.getElementById('unitPriceInput').value) || 0;
        document.getElementById('totalAmountInput').value = (qty * price).toFixed(2);
    }

    // Auto-fill unit price when product changes
    document.getElementById('productSelect').addEventListener('change', function() {
        var selectedOption = this.options[this.selectedIndex];
        var price = selectedOption.getAttribute('data-price');
        if (price) {
            document.getElementById('unitPriceInput').value = price;
            calculateTotal();
        }
    });

    function loadPurchase(id) {
        fetch('/StockPurchase/Edit/' + id)
        .then(response => response.text())
        .then(html => {
            document.getElementById('editPurchaseContainer').innerHTML = html;
            new bootstrap.Modal(document.getElementById('editPurchaseModal')).show();
        });
    }
</script>