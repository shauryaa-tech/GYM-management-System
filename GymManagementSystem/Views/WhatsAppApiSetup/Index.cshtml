@model GymManagement.ViewModels.WhatsAppApiSetupViewModel
@{
    ViewData["Title"] = "WhatsApp API Setup";
}

<style>
    .page-header {
        background: linear-gradient(135deg, #059669, #0d9488);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .setup-card {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 8px 30px rgba(15, 23, 42, .08);
    }
    .copy-box {
        background: #f8fafc;
        border: 1px dashed #cbd5e1;
        border-radius: 12px;
        padding: 12px;
        word-break: break-all;
        font-size: 0.9rem;
    }
    .status-badge {
        border-radius: 999px;
        padding: 6px 14px;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .form-control, .form-select, .btn { border-radius: 10px; }
    .step-num {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #059669;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: 700;
        margin-right: 10px;
        flex-shrink: 0;
    }
    .provider-panel { display: none; }
    .provider-panel.active { display: block; }
</style>

<div class="page-header d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="fa-brands fa-whatsapp me-2"></i>WhatsApp API Setup</h2>
        <p class="mb-0 opacity-75">SmartPing WABA credentials yahan configure karein — Gupshup / Meta direct ki zaroorat nahi</p>
    </div>
    <span class="status-badge @(Model.IsConfigured ? "bg-white text-success" : "bg-white text-warning")">
        @(Model.IsConfigured ? "Configured" : "Not Configured")
    </span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card setup-card">
            <div class="card-body p-4">
                <form asp-action="Index" method="post" id="waSetupForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="HasExistingToken" />

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="IsEnabled" class="form-check-input" role="switch" />
                        <label asp-for="IsEnabled" class="form-check-label fw-semibold">Enable WhatsApp API</label>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ApiProvider" class="form-label fw-semibold"></label>
                        <select asp-for="ApiProvider" class="form-select" id="apiProviderSelect">
                            <option value="SmartPing">SmartPing (Recommended)</option>
                            <option value="Meta">Meta Cloud API (Direct)</option>
                        </select>
                        <div class="form-text">Default: <strong>SmartPing</strong> — aapke SmartPing dashboard se milne wala API token use karein.</div>
                    </div>

                    <div id="smartPingPanel" class="provider-panel active">
                        <div class="alert alert-info py-2 small">
                            SmartPing Meta WABA proxy use karta hai. Dashboard se <strong>API Token</strong>, <strong>Phone Number ID</strong> aur <strong>Business Number</strong> copy karke yahan paste karein.
                        </div>
                    </div>

                    <div id="metaPanel" class="provider-panel">
                        <div class="alert alert-secondary py-2 small">
                            Sirf tab use karein jab aap directly Meta Developer Console se connect kar rahe hon (SmartPing ke bina).
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ApiBaseUrl" class="form-label fw-semibold"></label>
                            <input asp-for="ApiBaseUrl" class="form-control" placeholder="https://graph.facebook.com" />
                            <div class="form-text">SmartPing dashboard me jo API base URL diya ho — default chhod sakte ho.</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GraphApiVersion" class="form-label fw-semibold"></label>
                            <input asp-for="GraphApiVersion" class="form-control" placeholder="v21.0" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumberId" class="form-label fw-semibold"></label>
                            <input asp-for="PhoneNumberId" class="form-control" placeholder="SmartPing / WABA Phone Number ID" />
                            <span asp-validation-for="PhoneNumberId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BusinessPhone" class="form-label fw-semibold"></label>
                            <input asp-for="BusinessPhone" class="form-control" placeholder="e.g. 919876543210" />
                            <span asp-validation-for="BusinessPhone" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WabaId" class="form-label fw-semibold"></label>
                            <input asp-for="WabaId" class="form-control" placeholder="WhatsApp Business Account ID (optional)" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AppId" class="form-label fw-semibold"></label>
                            <input asp-for="AppId" class="form-control" placeholder="App / Business name (optional)" />
                        </div>
                        <div class="col-12">
                            <label asp-for="AccessToken" class="form-label fw-semibold"></label>
                            <input asp-for="AccessToken" class="form-control" autocomplete="new-password"
                                   placeholder="@(Model.HasExistingToken ? "Leave blank to keep existing token" : "SmartPing API Token")" />
                            @if (Model.HasExistingToken)
                            {
                                <div class="form-text text-success"><i class="fa fa-check-circle me-1"></i>API token already saved (encrypted)</div>
                            }
                            <span asp-validation-for="AccessToken" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VerifyToken" class="form-label fw-semibold"></label>
                            <input asp-for="VerifyToken" class="form-control" placeholder="Webhook verify token" />
                            <div class="form-text">SmartPing / webhook setup me yahi token daalein</div>
                        </div>
                        <div class="col-12">
                            <label asp-for="WelcomeMessage" class="form-label fw-semibold"></label>
                            <textarea asp-for="WelcomeMessage" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    @if (Model.LastModified.HasValue)
                    {
                        <p class="text-muted small mt-3 mb-0">Last updated: @Model.LastModified.Value.ToString("dd MMM yyyy, hh:mm tt")</p>
                    }

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-success">
                            <i class="fa fa-save me-2"></i>Save Settings
                        </button>
                        <button type="button" class="btn btn-outline-primary" id="btnTestConnection">
                            <i class="fa fa-plug me-2"></i>Test Connection
                        </button>
                        <a asp-controller="WhatsAppBot" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fa-brands fa-whatsapp me-2"></i>WhatsApp Bot
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card setup-card mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Webhook URL</h5>
                <p class="text-muted small">SmartPing dashboard → Webhook / Callback URL</p>
                <div class="copy-box mb-2" id="webhookBox">@Model.WebhookUrl</div>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyText('webhookBox')">
                    <i class="fa fa-copy me-1"></i>Copy Webhook URL
                </button>
                <p class="small text-muted mt-3 mb-0">
                    <strong>Verify Token:</strong> form mein jo token save kiya hai wahi webhook mein daalein.<br />
                    Subscribe to: <code>messages</code>
                </p>
            </div>
        </div>

        <div class="card setup-card mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Public Join Form</h5>
                <div class="copy-box mb-2" id="formBox">@Model.FormUrl</div>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="copyText('formBox')">
                    <i class="fa fa-copy me-1"></i>Copy Form URL
                </button>
            </div>
        </div>

        <div class="card setup-card">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">SmartPing Setup Steps</h5>
                <div class="d-flex mb-3">
                    <span class="step-num">1</span>
                    <div class="small">SmartPing dashboard par login karein aur WhatsApp Business API (WABA) activate karein</div>
                </div>
                <div class="d-flex mb-3">
                    <span class="step-num">2</span>
                    <div class="small"><strong>API Token</strong>, <strong>Phone Number ID</strong> aur business number copy karke upar save karein</div>
                </div>
                <div class="d-flex mb-3">
                    <span class="step-num">3</span>
                    <div class="small">Webhook URL copy karke SmartPing me paste karein + Verify Token match karein</div>
                </div>
                <div class="d-flex mb-3">
                    <span class="step-num">4</span>
                    <div class="small">Local test ke liye ngrok: <code>ngrok http 5xxx</code> — public URL webhook mein daalein</div>
                </div>
                <div class="d-flex">
                    <span class="step-num">5</span>
                    <div class="small"><strong>Test Connection</strong> → phir WhatsApp Bot se join form link share karein</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function copyText(id) {
            const text = document.getElementById(id)?.innerText || '';
            navigator.clipboard.writeText(text);
        }

        function toggleProviderPanels() {
            const provider = document.getElementById('apiProviderSelect')?.value || 'SmartPing';
            document.getElementById('smartPingPanel')?.classList.toggle('active', provider === 'SmartPing');
            document.getElementById('metaPanel')?.classList.toggle('active', provider === 'Meta');
        }

        document.getElementById('apiProviderSelect')?.addEventListener('change', toggleProviderPanels);
        toggleProviderPanels();

        document.getElementById('btnTestConnection')?.addEventListener('click', async function () {
            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<i class="fa fa-spinner fa-spin me-2"></i>Testing...';

            const token = document.querySelector('[name="__RequestVerificationToken"]')?.value;
            const payload = {
                apiProvider: document.getElementById('ApiProvider')?.value,
                apiBaseUrl: document.getElementById('ApiBaseUrl')?.value,
                phoneNumberId: document.getElementById('PhoneNumberId')?.value,
                accessToken: document.getElementById('AccessToken')?.value,
                graphApiVersion: document.getElementById('GraphApiVersion')?.value
            };

            try {
                const response = await fetch('@Url.Action("TestConnection")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(payload)
                });
                const data = await response.json();
                alert(data.message);
            } catch {
                alert('Test connection failed. Please try again.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fa fa-plug me-2"></i>Test Connection';
            }
        });
    </script>
}
