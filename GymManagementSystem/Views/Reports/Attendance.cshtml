@model GymManagement.ViewModels.AttendanceReportViewModel
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Attendance Report";
}

<partial name="_ReportStyles" />

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">Attendance Report</h2>
            <p class="mb-0">Member check-in history for the selected period</p>
        </div>
        @await Component.InvokeAsync("ExportImport", new { module = "ReportAttendance", exportAction = "ExportAttendance" })
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body">
                <h6>Total Records</h6>
                <h2>@Model.TotalRecords</h2>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card stats-card bg-success text-white">
            <div class="card-body">
                <h6>Unique Members</h6>
                <h2>@Model.UniqueMembers</h2>
            </div>
        </div>
    </div>
</div>

<div class="card filter-card shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold">From Date</label>
                <input type="date" name="fromDate" class="form-control"
                       value="@Model.FromDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">To Date</label>
                <input type="date" name="toDate" class="form-control"
                       value="@Model.ToDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-2"></i>Apply Filter
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card table-card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Member Code</th>
                        <th>Member Name</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No attendance records found for this period.
                            </td>
                        </tr>
                    }
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>@row.AttendanceDate.ToString("dd-MMM-yyyy")</td>
                            <td>@row.MemberCode</td>
                            <td>@row.MemberName</td>
                            <td>@(row.CheckInTime?.ToString(@"hh\:mm") ?? "-")</td>
                            <td>@(row.CheckOutTime?.ToString(@"hh\:mm") ?? "-")</td>
                            <td>@row.Remarks</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
