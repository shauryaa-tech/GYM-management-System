@model GymManagement.Models.PTSession

<form method="post" asp-action="Update">
    <input type="hidden" name="SessionId" value="@Model.SessionId" />
    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Member</label>
            <select name="MemberId" class="form-select" required>
                <option value="">Select Member</option>
                @foreach (var member in ViewBag.Members)
                {
                    if (member.MemberId == Model.MemberId)
                    {
                        <option value="@member.MemberId" selected>@member.MemberCode - @member.MemberName</option>
                    }
                    else
                    {
                        <option value="@member.MemberId">@member.MemberCode - @member.MemberName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Trainer</label>
            <select name="TrainerId" class="form-select" required>
                <option value="">Select Trainer</option>
                @foreach (var trainer in ViewBag.Trainers)
                {
                    if (trainer.StaffId == Model.TrainerId)
                    {
                        <option value="@trainer.StaffId" selected>@trainer.StaffName</option>
                    }
                    else
                    {
                        <option value="@trainer.StaffId">@trainer.StaffName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Session Date</label>
            <input type="date" name="SessionDate" class="form-control" value="@Model.SessionDate.ToString("yyyy-MM-dd")" required />
        </div>
        <div class="col-md-6 mb-3">
            <label>Status</label>
            <select name="Status" class="form-select" required>
                @if (Model.Status == "Completed")
                {
                    <option value="Scheduled">Scheduled</option>
                    <option value="Completed" selected>Completed</option>
                    <option value="Cancelled">Cancelled</option>
                }
                else if (Model.Status == "Cancelled")
                {
                    <option value="Scheduled">Scheduled</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled" selected>Cancelled</option>
                }
                else
                {
                    <option value="Scheduled" selected>Scheduled</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label>Start Time</label>
            <input type="time" name="StartTime" class="form-control" value="@Model.StartTime?.ToString(@"HH\:mm")" />
        </div>
        <div class="col-md-6 mb-3">
            <label>End Time</label>
            <input type="time" name="EndTime" class="form-control" value="@Model.EndTime?.ToString(@"HH\:mm")" />
        </div>
        <div class="col-md-12 mb-3">
            <label>Remarks</label>
            <textarea name="Remarks" class="form-control" rows="2">@Model.Remarks</textarea>
        </div>
    </div>
    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-warning">
            <i class="fas fa-save me-2"></i>Update Session
        </button>
    </div>
</form>
