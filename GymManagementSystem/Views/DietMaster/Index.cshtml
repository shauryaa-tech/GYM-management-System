@model List<GymManagement.Models.DietMaster>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Diet Master";

    int totalDiets = Model.Count;
    int activeDiets = Model.Count(x => x.IsActive);
    int inactiveDiets = Model.Count(x => !x.IsActive);
}

<style>
    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }
    .stats-card:hover {
        transform: translateY(-5px);
    }
    .form-control, .form-select { border-radius: 10px; }
    .btn { border-radius: 10px; }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold mb-1">Diet Master</h2>
            <p class="mb-0">Manage diet items and nutrition</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "DietMaster", allowImport = true })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "DietMaster"))
            {
                <button class="btn btn-light btn-lg"
                        data-bs-toggle="collapse"
                        data-bs-target="#dietForm">

                    <i class="fas fa-plus me-2"></i>
                    Add Diet

                </button>
            }
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card stats-card bg-primary text-white">
            <div class="card-body">
                <h6>Total Diets</h6>
                <h2>@totalDiets</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stats-card bg-success text-white">
            <div class="card-body">
                <h6>Active</h6>
                <h2>@activeDiets</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stats-card bg-dark text-white">
            <div class="card-body">
                <h6>Inactive</h6>
                <h2>@inactiveDiets</h2>
            </div>
        </div>
    </div>
</div>

<div class="collapse mb-4" id="dietForm">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Diet</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Save">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label>Diet Name</label>
                        <input type="text" name="DietName" class="form-control" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Category</label>
                        <select name="Category" class="form-select" required>
                            <option value="">Select Category</option>
                            <option>Veg</option>
                            <option>Non-Veg</option>
                            <option>Vegan</option>
                        </select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label>Meal Type</label>
                        <select name="MealType" class="form-select" required>
                            <option value="">Select Meal Type</option>
                            <option>Breakfast</option>
                            <option>Lunch</option>
                            <option>Dinner</option>
                            <option>Snack</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Calories</label>
                        <input type="number" step="0.01" min="0" name="Calories" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Protein (g)</label>
                        <input type="number" step="0.01" min="0" name="Protein" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Carbs (g)</label>
                        <input type="number" step="0.01" min="0" name="Carbs" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label>Fat (g)</label>
                        <input type="number" step="0.01" min="0" name="Fat" class="form-control" />
                    </div>
                    <div class="col-md-12 mb-3">
                        <label>Description</label>
                        <textarea name="Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save me-2"></i>Save Diet
                </button>
            </form>
        </div>
    </div>
</div>

<!-- SEARCH -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get">
            <div class="row">
                <div class="col-md-5">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search Name, Description..." />
                </div>
                <div class="col-md-3">
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        <option value="Veg" selected="@(ViewBag.Category == "Veg")">Veg</option>
                        <option value="Non-Veg" selected="@(ViewBag.Category == "Non-Veg")">Non-Veg</option>
                        <option value="Vegan" selected="@(ViewBag.Category == "Vegan")">Vegan</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary">Search</button>
                    <a asp-action="Index" class="btn btn-secondary">Reset</a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- TABLE -->
<div class="card shadow border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Diet Items (@Model.Count)</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Diet Name</th>
                        <th>Category</th>
                        <th>Meal Type</th>
                        <th>Calories</th>
                        <th>Protein</th>
                        <th>Carbs</th>
                        <th>Fat</th>
                        <th>Status</th>
                        <th width="180">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.DietName</td>
                                <td>@item.Category</td>
                                <td>@item.MealType</td>
                                <td>@item.Calories</td>
                                <td>@item.Protein</td>
                                <td>@item.Carbs</td>
                                <td>@item.Fat</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                Context,
                                                                PermissionRepo,
                                                                "DietMaster"))
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                onclick="loadDiet(@item.DietId)">

                                            Edit

                                        </button>
                                    }
                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                Context,
                                                                PermissionRepo,
                                                                "DietMaster"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.DietId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete Diet?')">

                                            Delete

                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted">No Diets Found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editDietModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Edit Diet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editDietContainer">
            </div>
        </div>
    </div>
</div>

<script>
    function loadDiet(id) {
        fetch('/DietMaster/Edit/' + id)
        .then(response => response.text())
        .then(html => {
            document.getElementById('editDietContainer').innerHTML = html;
            new bootstrap.Modal(document.getElementById('editDietModal')).show();
        });
    }
</script>
