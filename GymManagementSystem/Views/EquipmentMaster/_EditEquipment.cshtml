@model GymManagement.Models.EquipmentMaster

<form method="post" asp-action="Update">
    <input type="hidden" asp-for="EquipmentId" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Equipment Name</label>
            <input asp-for="EquipmentName" class="form-control" required />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Category</label>
            <input asp-for="Category" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Condition Status</label>
            <select asp-for="ConditionStatus" class="form-select">
                <option value="Good">Good</option>
                <option value="Fair">Fair</option>
                <option value="Poor">Poor</option>
            </select>
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Purchase Date</label>
            <input asp-for="PurchaseDate" type="date" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Status</label>
            <select asp-for="IsActive" class="form-select">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
            </select>
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Purchase Price</label>
            <input asp-for="PurchasePrice" type="number" step="0.01" min="0" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Quantity</label>
            <input asp-for="Quantity" type="number" min="1" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Location</label>
            <input asp-for="Location" class="form-control" />
        </div>
        <div class="col-md-12 mb-3">
            <label class="form-label">Remarks</label>
            <textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
        </div>
    </div>
    <div class="text-end">
        <button type="submit" class="btn btn-success">
            <i class="fas fa-save me-2"></i>Update Equipment
        </button>
    </div>
</form>
