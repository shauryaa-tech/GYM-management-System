@{
    Layout = null;
    ViewData["Title"] = "Welcome to CloudMex Gym";
    var whatsAppLink = ViewBag.WhatsAppLink as string;
    var leadId = ViewBag.LeadId;
    var paid = ViewBag.Paid as bool? == true || Context.Request.Query["paid"] == "true";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #14532d, #16a34a 50%, #2563eb);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            color: #fff;
        }
        .success-card {
            max-width: 560px;
            width: 100%;
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.2);
            border-radius: 24px;
            padding: 32px;
            backdrop-filter: blur(12px);
        }
    </style>
</head>
<body>
    <div class="success-card text-center">
        @if (paid)
        {
            <i class="fa-solid fa-circle-check fa-3x mb-3"></i>
            <h1 class="h3">Payment Successful!</h1>
            <p class="mb-4">Thank you for joining CloudMex Gym. Our team will contact you soon.</p>
        }
        else
        {
            <i class="fa-solid fa-user-check fa-3x mb-3"></i>
            <h1 class="h3">Lead Created Successfully</h1>
            <p class="mb-2">Reference: Lead #@leadId</p>
            <p class="mb-4">Open WhatsApp and continue to select trainer, class, membership plan and pay online.</p>

            @if (!string.IsNullOrWhiteSpace(whatsAppLink))
            {
                <a href="@whatsAppLink" target="_blank" class="btn btn-success btn-lg w-100 mb-3">
                    <i class="fa-brands fa-whatsapp me-2"></i>Continue on WhatsApp
                </a>
            }
        }

        <a href="/join" class="btn btn-outline-light">Submit Another Form</a>
    </div>
</body>
</html>
