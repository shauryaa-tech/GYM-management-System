@model GymManagement.ViewModels.StaffAttendanceHistoryViewModel
@{
    ViewData["Title"] = "Staff Attendance History";
    var monthNames = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames;
}

<style>
    .page-header {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }
    .month-card {
        border: none;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        overflow: hidden;
    }
    .month-card .card-header {
        background: linear-gradient(135deg, #f8fafc, #eef2ff);
        border-bottom: 1px solid #e2e8f0;
    }
    .stat-pill {
        border-radius: 14px;
        padding: 14px 12px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        height: 100%;
        text-align: center;
    }
    .staff-select-card {
        border-radius: 18px;
        border: 1px solid var(--cm-border, #e2e8f0);
        box-shadow: var(--cm-shadow-sm, 0 4px 14px rgba(0,0,0,.06));
    }
</style>

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1"><i class="fas fa-user-tie me-2"></i>Staff Attendance History</h2>
            <p class="mb-0 opacity-75">Staff select karein — month-wise poori attendance dekhein</p>
        </div>
        <a asp-action="Index" class="btn btn-light">
            <i class="fas fa-arrow-left me-2"></i>Staff Attendance
        </a>
    </div>
</div>

<div class="card staff-select-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-5">
                <label class="form-label fw-semibold">Staff</label>
                <select name="staffId" class="form-select" required>
                    <option value="">-- Staff choose karein --</option>
                    @foreach (var s in Model.StaffList)
                    {
                        <option value="@s.StaffId" selected="@(Model.SelectedStaffId == s.StaffId)">@s.Display</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Month</label>
                <select name="month" class="form-select">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.SelectedMonth)">@monthNames[m - 1]</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Year</label>
                <input type="number" name="year" class="form-control" value="@Model.SelectedYear" min="2020" max="2099" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-1"></i>View
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.SelectedStaff != null)
{
    var block = Model.SelectedMonthBlock;

    <div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid #7c3aed !important;">
        <div class="card-body">
            <h4 class="fw-bold mb-1">@Model.SelectedStaff.StaffName</h4>
            <div class="text-muted">
                @if (!string.IsNullOrEmpty(Model.SelectedStaff.Designation))
                {
                    <span class="me-3"><i class="fas fa-briefcase me-1"></i>@Model.SelectedStaff.Designation</span>
                }
                @if (!string.IsNullOrEmpty(Model.SelectedStaff.MobileNo))
                {
                    <span class="me-3"><i class="fas fa-phone me-1"></i>@Model.SelectedStaff.MobileNo</span>
                }
                <span><i class="fas fa-indian-rupee-sign me-1"></i>Basic: ₹@Model.SelectedStaff.BasicSalary.ToString("N0")</span>
            </div>
        </div>
    </div>

    <div class="card month-card">
        <div class="card-header py-3">
            <h5 class="mb-0 fw-bold">
                <i class="fas fa-calendar-alt text-primary me-2"></i>@block.MonthLabel
                <span class="badge bg-primary ms-2">@block.TotalMarked day(s) marked</span>
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-2 mb-4">
                <div class="col-6 col-md">
                    <div class="stat-pill">
                        <div class="text-muted small">Present</div>
                        <div class="fw-bold text-success fs-5">@block.PresentDays</div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="stat-pill">
                        <div class="text-muted small">Absent</div>
                        <div class="fw-bold text-danger fs-5">@block.AbsentDays</div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="stat-pill">
                        <div class="text-muted small">Leave</div>
                        <div class="fw-bold text-warning fs-5">@block.LeaveDays</div>
                    </div>
                </div>
                <div class="col-6 col-md">
                    <div class="stat-pill">
                        <div class="text-muted small">Half Day</div>
                        <div class="fw-bold text-info fs-5">@block.HalfDays</div>
                    </div>
                </div>
                <div class="col-12 col-md">
                    <div class="stat-pill">
                        <div class="text-muted small">Total Work Time</div>
                        <div class="fw-bold text-primary fs-6">@block.TotalWorkTime</div>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Day</th>
                            <th>Status</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Duration</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (block.Days.Count > 0)
                        {
                            @foreach (var day in block.Days.OrderBy(d => d.AttendanceDate))
                            {
                                <tr>
                                    <td><strong>@day.AttendanceDate.ToString("dd MMM yyyy")</strong></td>
                                    <td class="text-muted">@day.AttendanceDate.ToString("dddd")</td>
                                    <td><span class="badge @day.StatusBadgeClass">@day.StatusLabel</span></td>
                                    <td>@(day.FormattedCheckIn ?? "—")</td>
                                    <td>@(day.FormattedCheckOut ?? "—")</td>
                                    <td>@(day.WorkDuration ?? "—")</td>
                                    <td>@(string.IsNullOrWhiteSpace(day.Remarks) ? "—" : day.Remarks)</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    @block.MonthLabel me koi attendance record nahi mila
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="fas fa-user-tie fa-3x mb-3 d-block opacity-50"></i>
            <h5>Pehle staff aur month select karein</h5>
            <p class="mb-0">Us staff ki poori month-wise attendance yahan dikhegi</p>
        </div>
    </div>
}
