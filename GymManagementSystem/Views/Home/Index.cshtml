@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CloudMex — Gym Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #030712;
            --bg-soft: #0f172a;
            --card: rgba(15, 23, 42, 0.72);
            --border: rgba(148, 163, 184, 0.14);
            --text: #f8fafc;
            --muted: #94a3b8;
            --blue: #3b82f6;
            --blue-dark: #2563eb;
            --cyan: #22d3ee;
            --orange: #fb923c;
            --green: #34d399;
            --gradient: linear-gradient(135deg, #3b82f6 0%, #22d3ee 50%, #34d399 100%);
            --shadow: 0 25px 80px rgba(0, 0, 0, 0.45);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
            line-height: 1.6;
        }

        h1, h2, h3, .display-font {
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 0.04em;
            font-weight: 400;
        }

        .mesh-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background:
                radial-gradient(circle at 15% 20%, rgba(59, 130, 246, 0.22), transparent 35%),
                radial-gradient(circle at 85% 10%, rgba(34, 211, 238, 0.16), transparent 30%),
                radial-gradient(circle at 70% 80%, rgba(251, 146, 60, 0.12), transparent 35%),
                radial-gradient(circle at 10% 85%, rgba(52, 211, 153, 0.1), transparent 30%),
                linear-gradient(180deg, #030712 0%, #0f172a 50%, #030712 100%);
        }

        .grid-overlay {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            opacity: 0.35;
            background-image:
                linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 64px 64px;
            mask-image: radial-gradient(circle at center, black 30%, transparent 85%);
        }

        .page-wrap { position: relative; z-index: 1; }

        /* Navbar */
        .navbar-custom {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            padding: 1rem 0;
            transition: all 0.35s ease;
        }

        .navbar-custom.scrolled {
            background: rgba(3, 7, 18, 0.82);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border);
            padding: 0.65rem 0;
        }

        .nav-shell {
            max-width: 1240px;
            margin: 0 auto;
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: var(--text);
        }

        .brand-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: var(--gradient);
            display: grid;
            place-items: center;
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.35);
        }

        .brand-icon i { font-size: 1.25rem; color: white; }

        .brand-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.65rem;
            letter-spacing: 0.08em;
            line-height: 1;
        }

        .brand-text span { color: var(--cyan); }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            color: var(--muted);
            text-decoration: none;
            font-size: 0.92rem;
            font-weight: 600;
            transition: color 0.25s ease;
        }

        .nav-links a:hover { color: var(--text); }

        .btn-nav {
            background: var(--gradient);
            color: white;
            border: none;
            padding: 0.8rem 1.6rem;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.9rem;
            text-decoration: none;
            box-shadow: 0 12px 30px rgba(59, 130, 246, 0.35);
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .btn-nav:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 18px 40px rgba(59, 130, 246, 0.45);
        }

        .menu-toggle {
            display: none;
            background: rgba(255,255,255,0.06);
            border: 1px solid var(--border);
            color: white;
            width: 44px;
            height: 44px;
            border-radius: 12px;
        }

        .mobile-menu {
            display: none;
            position: fixed;
            top: 72px;
            left: 1rem;
            right: 1rem;
            background: rgba(15, 23, 42, 0.96);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 1rem;
            z-index: 999;
            backdrop-filter: blur(16px);
        }

        .mobile-menu.open { display: block; }

        .mobile-menu a {
            display: block;
            padding: 0.85rem 1rem;
            color: var(--text);
            text-decoration: none;
            font-weight: 600;
            border-radius: 12px;
        }

        .mobile-menu a:hover { background: rgba(255,255,255,0.05); }

        /* Hero */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 7rem 1.5rem 4rem;
        }

        .hero-grid {
            max-width: 1240px;
            margin: 0 auto;
            width: 100%;
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            gap: 3rem;
            align-items: center;
        }

        .hero-copy { animation: fadeUp 0.9s ease both; }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.55rem 1rem 0.55rem 0.55rem;
            border-radius: 999px;
            background: rgba(59, 130, 246, 0.12);
            border: 1px solid rgba(59, 130, 246, 0.25);
            color: #bfdbfe;
            font-size: 0.82rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
        }

        .pill-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--gradient);
            display: grid;
            place-items: center;
        }

        .hero-title {
            font-size: clamp(3.5rem, 8vw, 6.2rem);
            line-height: 0.95;
            margin-bottom: 1.25rem;
        }

        .hero-title .gradient-text {
            background: var(--gradient);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .hero-desc {
            color: var(--muted);
            font-size: 1.08rem;
            max-width: 540px;
            margin-bottom: 2rem;
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 2.5rem;
        }

        .btn-primary-lg, .btn-outline-lg {
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
            padding: 1rem 1.6rem;
            border-radius: 16px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .btn-primary-lg {
            background: var(--gradient);
            color: white;
            box-shadow: 0 16px 40px rgba(59, 130, 246, 0.35);
        }

        .btn-primary-lg:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 22px 50px rgba(59, 130, 246, 0.45);
        }

        .btn-outline-lg {
            color: var(--text);
            border: 1px solid var(--border);
            background: rgba(255,255,255,0.03);
        }

        .btn-outline-lg:hover {
            color: var(--cyan);
            border-color: rgba(34, 211, 238, 0.35);
            transform: translateY(-3px);
        }

        .hero-trust {
            display: flex;
            flex-wrap: wrap;
            gap: 1.25rem;
        }

        .trust-chip {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            color: var(--muted);
            font-size: 0.88rem;
            font-weight: 600;
        }

        .trust-chip i { color: var(--green); }

        /* Dashboard preview */
        .hero-visual {
            position: relative;
            animation: fadeUp 0.9s ease 0.15s both;
        }

        .preview-glow {
            position: absolute;
            inset: 10% -5% -10% -5%;
            background: radial-gradient(circle, rgba(59,130,246,0.35), transparent 65%);
            filter: blur(40px);
            z-index: 0;
        }

        .preview-card {
            position: relative;
            z-index: 1;
            background: rgba(15, 23, 42, 0.88);
            border: 1px solid var(--border);
            border-radius: 28px;
            padding: 1.25rem;
            box-shadow: var(--shadow);
            backdrop-filter: blur(12px);
            transform: perspective(1200px) rotateY(-8deg) rotateX(4deg);
            transition: transform 0.5s ease;
        }

        .preview-card:hover {
            transform: perspective(1200px) rotateY(-4deg) rotateX(2deg) translateY(-6px);
        }

        .preview-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .preview-dots { display: flex; gap: 0.4rem; }
        .preview-dots span {
            width: 10px; height: 10px; border-radius: 50%;
            background: rgba(255,255,255,0.15);
        }
        .preview-dots span:nth-child(1) { background: #ef4444; }
        .preview-dots span:nth-child(2) { background: #f59e0b; }
        .preview-dots span:nth-child(3) { background: #22c55e; }

        .preview-title {
            font-size: 0.82rem;
            color: var(--muted);
            font-weight: 600;
        }

        .preview-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.85rem;
            margin-bottom: 1rem;
        }

        .mini-stat {
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 1rem;
        }

        .mini-stat small {
            display: block;
            color: var(--muted);
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 0.35rem;
        }

        .mini-stat strong {
            font-size: 1.45rem;
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 0.04em;
        }

        .mini-stat.up strong { color: var(--green); }
        .mini-stat.blue strong { color: var(--cyan); }

        .preview-chart {
            height: 140px;
            border-radius: 18px;
            background: linear-gradient(180deg, rgba(59,130,246,0.15), rgba(59,130,246,0.02));
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
            margin-bottom: 1rem;
        }

        .chart-bars {
            position: absolute;
            inset: auto 1rem 1rem 1rem;
            display: flex;
            align-items: end;
            gap: 0.55rem;
            height: 90px;
        }

        .chart-bars span {
            flex: 1;
            border-radius: 8px 8px 4px 4px;
            background: linear-gradient(180deg, var(--cyan), var(--blue-dark));
            animation: barGrow 1.2s ease both;
        }

        .chart-bars span:nth-child(1) { height: 45%; animation-delay: 0.1s; }
        .chart-bars span:nth-child(2) { height: 72%; animation-delay: 0.2s; }
        .chart-bars span:nth-child(3) { height: 58%; animation-delay: 0.3s; }
        .chart-bars span:nth-child(4) { height: 88%; animation-delay: 0.4s; }
        .chart-bars span:nth-child(5) { height: 65%; animation-delay: 0.5s; }
        .chart-bars span:nth-child(6) { height: 92%; animation-delay: 0.6s; }

        .preview-list {
            display: grid;
            gap: 0.65rem;
        }

        .preview-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 0.9rem;
            border-radius: 14px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.04);
            font-size: 0.86rem;
        }

        .preview-row .badge-live {
            background: rgba(52, 211, 153, 0.15);
            color: var(--green);
            padding: 0.2rem 0.55rem;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .float-card {
            position: absolute;
            background: rgba(15, 23, 42, 0.95);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 0.85rem 1rem;
            box-shadow: var(--shadow);
            animation: floatY 4s ease-in-out infinite;
        }

        .float-card.one {
            top: -18px;
            right: -12px;
            animation-delay: 0s;
        }

        .float-card.two {
            bottom: 24px;
            left: -24px;
            animation-delay: 1.2s;
        }

        .float-card strong {
            display: block;
            font-size: 1.1rem;
            color: var(--orange);
            font-family: 'Bebas Neue', sans-serif;
        }

        .float-card span {
            color: var(--muted);
            font-size: 0.78rem;
            font-weight: 600;
        }

        /* Marquee */
        .marquee-wrap {
            border-block: 1px solid var(--border);
            background: rgba(255,255,255,0.02);
            overflow: hidden;
            padding: 1rem 0;
        }

        .marquee-track {
            display: flex;
            gap: 3rem;
            width: max-content;
            animation: marquee 28s linear infinite;
        }

        .marquee-item {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            color: var(--muted);
            font-weight: 700;
            font-size: 0.92rem;
            white-space: nowrap;
        }

        .marquee-item i { color: var(--cyan); }

        /* Sections */
        .section {
            padding: 6rem 1.5rem;
        }

        .section-shell {
            max-width: 1240px;
            margin: 0 auto;
        }

        .section-head {
            text-align: center;
            max-width: 720px;
            margin: 0 auto 3.5rem;
        }

        .section-label {
            display: inline-block;
            color: var(--cyan);
            font-size: 0.8rem;
            font-weight: 800;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            margin-bottom: 0.75rem;
        }

        .section-title {
            font-size: clamp(2.4rem, 5vw, 3.8rem);
            line-height: 1;
            margin-bottom: 1rem;
        }

        .section-desc {
            color: var(--muted);
            font-size: 1.05rem;
        }

        /* Features */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
        }

        .feature-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 1.75rem;
            backdrop-filter: blur(10px);
            transition: all 0.35s ease;
            position: relative;
            overflow: hidden;
        }

        .feature-card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(59,130,246,0.12), transparent 55%);
            opacity: 0;
            transition: opacity 0.35s ease;
        }

        .feature-card:hover {
            transform: translateY(-8px);
            border-color: rgba(59, 130, 246, 0.35);
            box-shadow: 0 24px 60px rgba(0,0,0,0.35);
        }

        .feature-card:hover::after { opacity: 1; }

        .feature-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            display: grid;
            place-items: center;
            margin-bottom: 1.25rem;
            background: rgba(59, 130, 246, 0.12);
            color: var(--cyan);
            font-size: 1.35rem;
            position: relative;
            z-index: 1;
        }

        .feature-card h3 {
            font-size: 1.45rem;
            margin-bottom: 0.65rem;
            position: relative;
            z-index: 1;
        }

        .feature-card p {
            color: var(--muted);
            font-size: 0.95rem;
            position: relative;
            z-index: 1;
        }

        /* Steps */
        .steps-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }

        .step-card {
            text-align: center;
            padding: 2rem 1.5rem;
            border-radius: 24px;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
        }

        .step-num {
            width: 56px;
            height: 56px;
            margin: 0 auto 1.25rem;
            border-radius: 50%;
            display: grid;
            place-items: center;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.5rem;
            background: var(--gradient);
            color: white;
        }

        .step-card h3 { font-size: 1.6rem; margin-bottom: 0.75rem; }
        .step-card p { color: var(--muted); }

        /* About */
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }

        .about-panel {
            border-radius: 28px;
            padding: 2rem;
            background: linear-gradient(145deg, rgba(59,130,246,0.18), rgba(34,211,238,0.08));
            border: 1px solid rgba(59,130,246,0.22);
            position: relative;
            overflow: hidden;
        }

        .about-panel::before {
            content: '';
            position: absolute;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(251,146,60,0.15);
            top: -80px;
            right: -60px;
        }

        .about-stat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            position: relative;
            z-index: 1;
        }

        .about-stat {
            background: rgba(3,7,18,0.55);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 1.25rem;
        }

        .about-stat strong {
            display: block;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.2rem;
            color: var(--cyan);
            line-height: 1;
        }

        .about-stat span {
            color: var(--muted);
            font-size: 0.88rem;
            font-weight: 600;
        }

        .about-copy h2 {
            font-size: clamp(2.4rem, 4vw, 3.5rem);
            line-height: 1;
            margin-bottom: 1rem;
        }

        .about-copy p {
            color: var(--muted);
            margin-bottom: 1rem;
        }

        .check-list {
            list-style: none;
            margin-top: 1.5rem;
        }

        .check-list li {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 0.85rem;
            font-weight: 600;
        }

        .check-list i {
            color: var(--green);
            font-size: 1.1rem;
        }

        /* Testimonials */
        .testimonial-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
        }

        .testimonial {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 1.75rem;
        }

        .stars { color: #fbbf24; margin-bottom: 1rem; }

        .testimonial p {
            color: var(--muted);
            margin-bottom: 1.25rem;
            font-size: 0.96rem;
        }

        .author {
            display: flex;
            align-items: center;
            gap: 0.85rem;
        }

        .avatar {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            background: var(--gradient);
            display: grid;
            place-items: center;
            font-weight: 800;
            color: white;
        }

        .author strong { display: block; font-size: 0.95rem; }
        .author span { color: var(--muted); font-size: 0.82rem; }

        /* CTA */
        .cta-box {
            border-radius: 32px;
            padding: 4rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            background:
                radial-gradient(circle at top right, rgba(34,211,238,0.18), transparent 35%),
                linear-gradient(135deg, rgba(59,130,246,0.25), rgba(15,23,42,0.95));
            border: 1px solid rgba(59,130,246,0.25);
            box-shadow: var(--shadow);
        }

        .cta-box h2 {
            font-size: clamp(2.5rem, 5vw, 4rem);
            line-height: 1;
            margin-bottom: 1rem;
        }

        .cta-box p {
            color: var(--muted);
            max-width: 620px;
            margin: 0 auto 2rem;
            font-size: 1.05rem;
        }

        /* Footer */
        .footer {
            padding: 2.5rem 1.5rem;
            border-top: 1px solid var(--border);
            background: rgba(3,7,18,0.9);
        }

        .footer-shell {
            max-width: 1240px;
            margin: 0 auto;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .footer-links {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem;
        }

        .footer-links a {
            color: var(--muted);
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 600;
        }

        .footer-links a:hover { color: var(--cyan); }

        .footer-copy {
            color: var(--muted);
            font-size: 0.82rem;
        }

        /* Reveal animation */
        .reveal {
            opacity: 0;
            transform: translateY(28px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @@keyframes floatY {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        @@keyframes barGrow {
            from { transform: scaleY(0); transform-origin: bottom; }
            to { transform: scaleY(1); transform-origin: bottom; }
        }

        @@keyframes marquee {
            from { transform: translateX(0); }
            to { transform: translateX(-50%); }
        }

        @@media (max-width: 992px) {
