@model List<GymManagement.Models.LeadSourceMaster>
@inject GymManagement.Data.Repositories.RolePermissionRepository PermissionRepo

@{
    ViewData["Title"] = "Lead Source Master";

    int totalSources = Model.Count;
    int activeSources = Model.Count(x => x.IsActive);
    int inactiveSources = Model.Count(x => !x.IsActive);
}

<style>

    .page-header {
        background: linear-gradient(135deg,#2563eb,#7c3aed);
        color: white;
        border-radius: 20px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .stats-card {
        border: none;
        border-radius: 18px;
        transition: .3s;
    }

        .stats-card:hover {
            transform: translateY(-5px);
        }

    .form-control,
    .form-select {
        border-radius: 10px;
    }

    .btn {
        border-radius: 10px;
    }
</style>

<div class="page-header">

    <div class="d-flex justify-content-between align-items-center">

        <div>

            <h2 class="fw-bold mb-1">
                Lead Source Master
            </h2>

            <p class="mb-0">
                Manage Lead Sources
            </p>

        </div>

        <div class="d-flex gap-2 align-items-center">
            @await Component.InvokeAsync("ExportImport", new { module = "LeadSources", allowImport = true })
            @if (GymManagement.Helpers.PermissionHelper.CanAdd(
                    Context,
                    PermissionRepo,
                    "LeadSources"))
            {
                <button class="btn btn-light btn-lg"
                        data-bs-toggle="collapse"
                        data-bs-target="#leadSourceForm">

                    <i class="fas fa-plus me-2"></i>
                    Add Lead Source

                </button>
            }
        </div>

    </div>

</div>

<div class="row mb-4">

    <div class="col-md-4">

        <div class="card stats-card bg-primary text-white">

            <div class="card-body">

                <h6>Total Sources</h6>

                <h2>@totalSources</h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card stats-card bg-success text-white">

            <div class="card-body">

                <h6>Active</h6>

                <h2>@activeSources</h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card stats-card bg-danger text-white">

            <div class="card-body">

                <h6>Inactive</h6>

                <h2>@inactiveSources</h2>

            </div>

        </div>

    </div>

</div>

<div class="collapse mb-4"
     id="leadSourceForm">

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">
                Add Lead Source
            </h5>

        </div>

        <div class="card-body">

            <form method="post"
                  asp-action="Save">

                <div class="row">

                    <div class="col-md-3 mb-3">

                        <label>Source Name</label>

                        <input type="text"
                               name="SourceName"
                               class="form-control"
                               required />

                    </div>

                    <div class="col-md-3 mb-3">

                        <label>Display Order</label>

                        <input type="number"
                               name="DisplayOrder"
                               value="1"
                               min="1"
                               class="form-control" />

                    </div>

                    <div class="col-md-3 mb-3">

                        <label>Status</label>

                        <select name="IsActive"
                                class="form-select">

                            <option value="true">
                                Active
                            </option>

                            <option value="false">
                                Inactive
                            </option>

                        </select>

                    </div>

                    <div class="col-md-12 mb-3">

                        <label>Description</label>

                        <textarea name="Description"
                                  rows="3"
                                  class="form-control"></textarea>

                    </div>

                </div>

                <button type="submit"
                        class="btn btn-success">

                    <i class="fas fa-save me-2"></i>

                    Save Lead Source

                </button>

            </form>

        </div>

    </div>

</div>

<div class="card shadow-sm border-0 mb-4">

    <div class="card-body">

        <form method="get">

            <div class="row">

                <div class="col-md-8">

                    <input type="text"
                           name="search"
                           value="@ViewBag.Search"
                           class="form-control"
                           placeholder="Search Lead Source..." />

                </div>

                <div class="col-md-4">

                    <button class="btn btn-primary">

                        Search

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Reset

                    </a>

                </div>

            </div>

        </form>

    </div>

</div>
<div class="card shadow border-0">

    <div class="card-header bg-dark text-white">

        <h5 class="mb-0">

            Lead Sources (@Model.Count)

        </h5>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="table-light">

                    <tr>

                        <th>Code</th>

                        <th>Source Name</th>

                        <th>Description</th>

                        <th>Display Order</th>

                        <th>Status</th>

                        <th width="180">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.Count > 0)
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>

                                    <span class="badge bg-primary">

                                        @item.SourceCode

                                    </span>

                                </td>

                                <td>

                                    <strong>

                                        @item.SourceName

                                    </strong>

                                </td>

                                <td>

                                    @(string.IsNullOrWhiteSpace(item.Description)
                                                                ? "-"
                                                                : item.Description)

                        </td>

                                <td>

                                    @item.DisplayOrder

                                </td>

                                <td>

                            @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">

                                            Active

                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">

                                            Inactive

                                        </span>
                                    }

                                </td>

                                <td>

                                    @if (GymManagement.Helpers.PermissionHelper.CanEdit(
                                                                Context,
                                                                PermissionRepo,
                                                                "LeadSources"))
                                    {
                                        <button class="btn btn-warning btn-sm"
                                                onclick="loadLeadSource(@item.LeadSourceId)">

                                            <i class="fas fa-edit"></i>

                                            Edit

                                        </button>
                                    }

                                    @if (GymManagement.Helpers.PermissionHelper.CanDelete(
                                                                Context,
                                                                PermissionRepo,
                                                                "LeadSources"))
                                    {
                                        <a asp-action="Delete"
                                           asp-route-id="@item.LeadSourceId"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('Delete Lead Source?')">

                                            <i class="fas fa-trash"></i>

                                            Delete

                                        </a>
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="6"
                                class="text-center text-muted">

                                No Lead Sources Found

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
<!-- EDIT MODAL -->

<div class="modal fade"
     id="editLeadSourceModal">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header bg-warning">

                <h5 class="modal-title">

                    <i class="fas fa-edit me-2"></i>

                    Edit Lead Source

                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body"
                 id="editLeadSourceContainer">
            </div>

        </div>

    </div>

</div>

<script>

    function loadLeadSource(id)
    {
        fetch('/LeadSources/Edit/' + id)
        .then(response => response.text())
        .then(html =>
        {
            document.getElementById(
                'editLeadSourceContainer'
            ).innerHTML = html;

            new bootstrap.Modal(
                document.getElementById(
                    'editLeadSourceModal'
                )
            ).show();
        });
    }

</script>