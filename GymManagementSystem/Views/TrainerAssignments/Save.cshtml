@model GymManagement.Models.TrainerAssignmentModel

@{
    ViewData["Title"] = "Assign Trainer";
}

<div class="container-fluid">

    <div class="row">

        <div class="col-lg-8 mx-auto">

            <div class="card shadow border-0">

                <div class="card-header bg-primary text-white">

                    <h4 class="mb-0">

                        Assign Trainer

                    </h4>

                </div>

                <div class="card-body">

                    <form asp-action="Save"
                          method="post">

                        <div class="row">

                            <!-- Member -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">

                                    Member

                                </label>

                                <select asp-for="MemberId"
                                        asp-items="ViewBag.MemberList"
                                        class="form-select">

                                    <option value="">

                                        Select Member

                                    </option>

                                </select>

                                <span asp-validation-for="MemberId"
                                      class="text-danger"></span>

                            </div>

                            <!-- Trainer -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">

                                    Trainer

                                </label>

                                <select asp-for="TrainerId"
                                        asp-items="ViewBag.TrainerList"
                                        class="form-select">

                                    <option value="">

                                        Select Trainer

                                    </option>

                                </select>

                                <span asp-validation-for="TrainerId"
                                      class="text-danger"></span>

                            </div>

                            <!-- Start Date -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">

                                    Start Date

                                </label>

                                <input asp-for="StartDate"
                                       type="date"
                                       class="form-control" />

                            </div>

                            <!-- End Date -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label">

                                    End Date

                                </label>

                                <input asp-for="EndDate"
                                       type="date"
                                       class="form-control" />

                            </div>

                            <!-- Remarks -->

                            <div class="col-md-12 mb-3">

                                <label class="form-label">

                                    Remarks

                                </label>

                                <textarea asp-for="Remarks"
                                          rows="4"
                                          class="form-control"></textarea>

                            </div>

                            <!-- Status -->

                            <div class="col-md-12 mb-4">

                                <div class="form-check form-switch">

                                    <input asp-for="IsActive"
                                           class="form-check-input" />

                                    <label class="form-check-label">

                                        Active Assignment

                                    </label>

                                </div>

                            </div>

                            <!-- Buttons -->

                            <div class="col-md-12">

                                <button type="submit"
                                        class="btn btn-success">

                                    <i class="fas fa-save"></i>

                                    Save Assignment

                                </button>

                                <a asp-action="Index"
                                   class="btn btn-secondary">

                                    Cancel

                                </a>

                            </div>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial");
    }

}