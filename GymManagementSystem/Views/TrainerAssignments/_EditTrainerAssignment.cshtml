@model GymManagement.Models.TrainerAssignmentModel

<form asp-action="Edit"
      method="post">

    <input asp-for="AssignmentId"
           type="hidden" />

    <div class="row">

        <!-- Member -->

        <div class="col-md-6 mb-3">

            <label class="form-label">

                Member

            </label>

            <select asp-for="MemberId"
                    asp-items="ViewBag.MemberList"
                    class="form-select">
            </select>

            <span asp-validation-for="MemberId"
                  class="text-danger"></span>

        </div>

        <!-- Trainer -->

        <div class="col-md-6 mb-3">

            <label class="form-label">

                Trainer

            </label>

            <select asp-for="TrainerId"
                    asp-items="ViewBag.TrainerList"
                    class="form-select">
            </select>

            <span asp-validation-for="TrainerId"
                  class="text-danger"></span>

        </div>

        <!-- Start Date -->

        <div class="col-md-6 mb-3">

            <label class="form-label">

                Start Date

            </label>

            <input asp-for="StartDate"
                   type="date"
                   class="form-control" />

        </div>

        <!-- End Date -->

        <div class="col-md-6 mb-3">

            <label class="form-label">

                End Date

            </label>

            <input asp-for="EndDate"
                   type="date"
                   class="form-control" />

        </div>

        <!-- Remarks -->

        <div class="col-md-12 mb-3">

            <label class="form-label">

                Remarks

            </label>

            <textarea asp-for="Remarks"
                      rows="3"
                      class="form-control">

            </textarea>

        </div>

        <!-- Status -->

        <div class="col-md-12 mb-4">

            <div class="form-check form-switch">

                <input asp-for="IsActive"
                       class="form-check-input" />

                <label class="form-check-label">

                    Active Assignment

                </label>

            </div>

        </div>

        <!-- Button -->

        <div class="col-md-12">

            <button class="btn btn-warning">

                <i class="fas fa-save"></i>

                Update Assignment

            </button>

        </div>

    </div>

</form>

@section Scripts
{
    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial");
    }
}